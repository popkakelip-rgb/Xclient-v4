-- КОНСТАНТЫ И ЦВЕТА
-- ═════════════════════════════════════════════════════════════════

local COLOR_BG = Color3.fromRGB(25, 25, 30)
local COLOR_ACCENT = Color3.fromRGB(100, 200, 255)
local COLOR_TEXT = Color3.fromRGB(220, 220, 220)
local COLOR_HOVER = Color3.fromRGB(50, 50, 60)
local COLOR_SUCCESS = Color3.fromRGB(100, 255, 100)
local COLOR_ERROR = Color3.fromRGB(255, 100, 100)
local COLOR_WARNING = Color3.fromRGB(255, 200, 100)

-- ═════════════════════════════════════════════════════════════════
-- DAMAGE FLY КОНФИГУРАЦИЯ
-- ═════════════════════════════════════════════════════════════════

local damageFlyConfig = {
    enabled = false,
    active = false,
    maxDuration = 10, -- 10 секунд макс (100%)
    currentDuration = 0,
    isCharging = false,
    chargeRate = 0.5, -- 5% в секунду (0.05 * 10)
    drainRate = 0.1, -- 10% в секунду (0.1 * 10)
    speed = 50,
    minDamageToActivate = 5, -- минимум 5% урона
    lastDamageTime = 0,
    damageTimeout = 0.5 -- через 0.5 сек после урона можно использовать
}

local localPlayer = Players.LocalPlayer
local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

local connections = {}
local isFlying = false
local currentVelocity = Vector3.new(0, 0, 0)
local lastHealth = humanoid.Health

-- ═════════════════════════════════════════════════════════════════
-- ФУНКЦИЯ УВЕДОМЛЕНИЙ
-- ═════════════════════════════════════════════════════════════════

local function showNotification(text, color)
    local playerGui = localPlayer:WaitForChild("PlayerGui")
    
    local notificationGui = Instance.new("ScreenGui")
    notificationGui.Name = "Notification"
    notificationGui.ResetOnSpawn = false
    notificationGui.DisplayOrder = 9998
    notificationGui.Parent = playerGui

    local notification = Instance.new("Frame")
    notification.Name = "NotificationFrame"
    notification.Size = UDim2.new(0, 300, 0, 60)
    notification.Position = UDim2.new(1, -320, 1, -80)
    notification.BackgroundColor3 = COLOR_BG
    notification.BorderSizePixel = 0
    notification.Parent = notificationGui

    local border = Instance.new("Frame")
    border.Name = "Border"
    border.Size = UDim2.new(0, 4, 1, 0)
    border.BackgroundColor3 = color or COLOR_ACCENT
    border.BorderSizePixel = 0
    border.Parent = notification

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -20, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = COLOR_TEXT
    label.TextSize = 12
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Center
    label.Parent = notification

    notification.Position = UDim2.new(1, 0, 1, -80)
    local slideIn = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local slideInTween = TweenService:Create(notification, slideIn, {Position = UDim2.new(1, -320, 1, -80)})
    slideInTween:Play()

    wait(3)
    local slideOut = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    local slideOutTween = TweenService:Create(notification, slideOut, {Position = UDim2.new(1, 0, 1, -80)})
    slideOutTween:Play()
    slideOutTween.Completed:Connect(function()
        notificationGui:Destroy()
    end)
end

-- ═════════════════════════════════════════════════════════════════
-- DAMAGE FLY HUD
-- ═════════════════════════════════════════════════════════════════

