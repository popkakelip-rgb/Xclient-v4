local hudElements = createDamageFlyHUD()

-- ═════════════════════════════════════════════════════════════════
-- ОБНОВЛЕНИЕ HUD
-- ═════════════════════════════════════════════════════════════════

local function updateDamageFlyHUD()
    local percent = math.floor((damageFlyConfig.currentDuration / damageFlyConfig.maxDuration) * 100)
    percent = math.max(0, math.min(100, percent))

    hudElements.percentText.Text = percent .. "%"

    -- Изменение цвета в зависимости от состояния
    local displayColor = COLOR_ACCENT
    local statusLabel = "Ready"

    if damageFlyConfig.active then
        displayColor = COLOR_SUCCESS
        statusLabel = "FLYING"
    elseif damageFlyConfig.isCharging then
        displayColor = COLOR_WARNING
        statusLabel = "Charging..."
    elseif percent <= 0 then
        displayColor = COLOR_ERROR
        statusLabel = "Depleted!"
    elseif percent < 30 then
        displayColor = COLOR_WARNING
        statusLabel = "Low Power"
    end

    hudElements.percentText.TextColor3 = displayColor
    hudElements.statusText.TextColor3 = displayColor
    hudElements.statusText.Text = statusLabel
    hudElements.outerStroke.Color = displayColor
    hudElements.innerCircle.BorderStroke.Color = displayColor

    -- Анимация размера в зависимости от состояния
    if damageFlyConfig.active then
        local newSize = 80 + math.sin(tick() * 5) * 3
        hudElements.container.Size = UDim2.new(0, newSize, 0, newSize)
    else
        hudElements.container.Size = UDim2.new(0, 80, 0, 80)
    end
end

-- ═════════════════════════════════════════════════════════════════
-- ОБРАБОТКА УРОНА
-- ═════════════════════════════════════════════════════════════════

local damageTakenConnection = humanoid.ChildAdded:Connect(function(child)
    if child.Name == "BodyVelocity" or child.Name == "BodyGyro" then return end
    
    local currentHealth = humanoid.Health
    local damageAmount = lastHealth - currentHealth
    
    if damageAmount > 0 then
        lastHealth = currentHealth
        damageFlyConfig.lastDamageTime = tick()
        
        -- Конвертируем урон в процент энергии (макс 100%)
        local maxHealth = humanoid.MaxHealth
        local damagePercent = (damageAmount / maxHealth) * 100
        
        -- Добавляем энергию (макс 100%)
        local newDuration = damageFlyConfig.currentDuration + (damagePercent * damageFlyConfig.maxDuration / 100)
        damageFlyConfig.currentDuration = math.min(newDuration, damageFlyConfig.maxDuration)
        
        showNotification("💥 +энергия! " .. math.floor(damagePercent) .. "%", COLOR_SUCCESS)
    end
end)

table.insert(connections, damageTakenConnection)

local healthChangedConnection = humanoid.HealthChanged:Connect(function(newHealth)
    if newHealth < lastHealth then
        local damageAmount = lastHealth - newHealth
        lastHealth = newHealth
        
        if not damageFlyConfig.isCharging then
            damageFlyConfig.isCharging = false
        end
    end
end)

table.insert(connections, healthChangedConnection)

-- ═════════════════════════════════════════════════════════════════
-- ФУНКЦИИ FLIGHT
-- ═════════════════════════════════════════════════════════════════

local function activateDamageFly()
    if damageFlyConfig.currentDuration < damageFlyConfig.minDamageToActivate then
        showNotification("✗ Недостаточно энергии!", COLOR_ERROR)
        return
    end
    
    if damageFlyConfig.active then
        deactivateDamageFly()
        return
    end

    damageFlyConfig.active = true
    showNotification("✓ Damage Fly активирован!", COLOR_SUCCESS)

    local oldVelocity = rootPart:FindFirstChild("DFlyVelocity")
    if oldVelocity then oldVelocity:Destroy() end
    
    local oldGyro = rootPart:FindFirstChild("DFlyGyro")
    if oldGyro then oldGyro:Destroy() end

    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Name = "DFlyVelocity"
    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVelocity.P = 1250
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart

    local bodyGyro = Instance.new("BodyGyro")
    bodyGyro.Name = "DFlyGyro"
    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyGyro.P = 3000
    bodyGyro.D = 500
    bodyGyro.Parent = rootPart

    local heartbeatConnection
    heartbeatConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not damageFlyConfig.active or not character.Parent or humanoid.Health <= 0 then
            heartbeatConnection:Disconnect()
            if bodyVelocity and bodyVelocity.Parent then bodyVelocity:Destroy() end
            if bodyGyro and bodyGyro.Parent then bodyGyro:Destroy() end
            damageFlyConfig.active = false
            return
        end

        -- Слив энергии
        damageFlyConfig.currentDuration = damageFlyConfig.currentDuration - (damageFlyConfig.drainRate * deltaTime)
        
        if damageFlyConfig.currentDuration <= 0 then
            damageFlyConfig.currentDuration = 0
            deactivateDamageFly()
            showNotification("✗ Энергия исчерпана!", COLOR_ERROR)
            return
        end

        -- Движение
        local moveDirection = humanoid.MoveDirection
        local isSprinting = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or 
                           UserInputService:IsKeyDown(Enum.KeyCode.RightShift)
        
        local currentSpeed = damageFlyConfig.speed * (isSprinting and 1.5 or 1)
        local spacePressed = UserInputService:IsKeyDown(Enum.KeyCode.Space)
        
        local flightDirection = moveDirection
        if flightDirection.Magnitude > 0 then
            flightDirection = flightDirection.Unit
        end
        
        local targetVelocity = flightDirection * currentSpeed
        targetVelocity = targetVelocity + Vector3.new(0, spacePressed and 10 or -5, 0)
        
        currentVelocity = currentVelocity:Lerp(targetVelocity, 0.15)
        
        bodyVelocity.Velocity = currentVelocity
        rootPart.AssemblyLinearVelocity = currentVelocity
        bodyGyro.CFrame = rootPart.CFrame
    end)
    
    table.insert(connections, heartbeatConnection)
end

local function deactivateDamageFly()
    damageFlyConfig.active = false
    
    local velocity = rootPart:FindFirstChild("DFlyVelocity")
    if velocity then velocity:Destroy() end
    
    local gyro = rootPart:FindFirstChild("DFlyGyro")
    if gyro then gyro:Destroy() end
    
    currentVelocity = Vector3.new(0, 0, 0)
    showNotification("✓ Damage Fly отключен!", COLOR_ERROR)
end

-- ═════════════════════════════════════════════════════════════════
-- HUD UPDATE LOOP
-- ═════════════════════════════════════════════════════════════════

local hudUpdateConnection = RunService.RenderStepped:Connect(function()
    updateDamageFlyHUD()
    
    -- Зарядка при простое
    if not damageFlyConfig.active and damageFlyConfig.currentDuration < damageFlyConfig.maxDuration then
        damageFlyConfig.currentDuration = damageFlyConfig.currentDuration + (damageFlyConfig.chargeRate * 0.016)
        damageFlyConfig.isCharging = true
    else
        damageFlyConfig.isCharging = false
    end
end)

table.insert(connections, hudUpdateConnection)

-- ═════════════════════════════════════════════════════════════════
-- ГОРЯЧАЯ КЛАВИША
-- ═════════════════════════════════════════════════════════════════

local inputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- X для Damage Fly
    if input.KeyCode == Enum.KeyCode.X then
        activateDamageFly()
    end
end)

table.insert(connections, inputConnection)

-- ═════════════════════════════════════════════════════════════════
-- ОЧИСТКА ПРИ СМЕРТИ
-- ═════════════════════════════════════════════════════════════════

local diedConnection = humanoid.Died:Connect(function()
    deactivateDamageFly()
    for _, conn in ipairs(connections) do
        if conn and conn.Connected then
            conn:Disconnect()
        end
    end
end)

table.insert(connections, diedConnection)

