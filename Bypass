local guiParent

local function getGuiParent()
	-- Попытка использовать CoreGui (защищает GUI от сброса при смерти)
	local success, err = pcall(function()
		local test = Instance.new("ScreenGui")
		test.Parent = CoreGui
		test:Destroy()
	end)
	
	if success then
		return CoreGui
	else
		-- Fallback на PlayerGui
		return player:WaitForChild("PlayerGui")
	end
end

guiParent = getGuiParent()

