--  1. MAGIC FLIGHT  (BodyVelocity + BodyGyro — работает везде)
-- ══════════════════════════════════════════════════════════════════
local function cleanFlyObjects()
    if flyBV then flyBV:Destroy(); flyBV = nil end
    if flyBG then flyBG:Destroy(); flyBG = nil end
end

local function stopFlight()
    if not flyOn then return end
    flyOn = false
    if flyConn then flyConn:Disconnect(); flyConn = nil end
    cleanFlyObjects()
    pcall(function() Hum.PlatformStand = false end)
end

local function startFlight()
    if flyOn then return end
    flyOn = true

    -- Создаём BodyVelocity (работает в 99% игр без network ownership)
    cleanFlyObjects()
    local bv = Instance.new("BodyVelocity")
    bv.Name          = "xcFlyBV"
    bv.MaxForce      = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity      = Vector3.zero
    bv.Parent        = Root
    flyBV            = bv

    local bg = Instance.new("BodyGyro")
    bg.Name          = "xcFlyBG"
    bg.MaxTorque     = Vector3.new(0, 1e5, 0)  -- только поворот по Y
    bg.P             = 5000
    bg.CFrame        = Root.CFrame
    bg.Parent        = Root
    flyBG            = bg

    Hum.PlatformStand = true

    -- Wobble состояние
    wobT=0; wobS=0; dC=0; dTgt=0; dTmr=0

    flyConn = RunService.Heartbeat:Connect(function(dt)
        -- Проверка живости
        if not (Root and Root.Parent) then stopFlight(); return end
        if Hum.Health <= 0 then stopFlight(); return end

        -- Направление по камере
        local cf   = Cam.CFrame
        local fwd  = Vector3.new(cf.LookVector.X, 0, cf.LookVector.Z)
        local rgt  = Vector3.new(cf.RightVector.X, 0, cf.RightVector.Z)
        if fwd.Magnitude > 0.001 then fwd = fwd.Unit end
        if rgt.Magnitude > 0.001 then rgt = rgt.Unit end

        local md  = Hum.MoveDirection
        local dir = Vector3.zero
        if md.Magnitude > 0.05 then
            local v = fwd * (-md.Z) + rgt * md.X
            if v.Magnitude > 0.001 then dir = v.Unit end
        end

        -- Вертикаль
        local vy = 0
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vy = 18
        elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
            or UserInputService:IsKeyDown(Enum.KeyCode.RightShift) then vy = -18 end

        -- Resolver
        local speedMult = 1
        if resolverOn then
            local mp = Root.Position; local found = false; local cl = math.huge
            for _, pl in ipairs(Players:GetPlayers()) do
                if pl == LP then continue end
                local ch = pl.Character; if not ch then continue end
                local r  = ch:FindFirstChild("HumanoidRootPart"); if not r then continue end
                local d  = (r.Position - mp).Magnitude
                if d < cl then cl = d end
                if d <= RDet then found = true; break end
            end
            if found then resActive = true
            elseif resActive and cl > RSafe then resActive = false end
            local tv = resActive and RRise or -RSink
            resVel = resVel + (tv - resVel) * RLerp
            resVel = math.clamp(resVel, -RSink, RRise)
            speedMult = resActive and RBoost or 1
        else
            resActive = false; resVel = 0
        end

        -- Покачивание 3 слоя
        wobT = wobT + dt * 1.6
        local sinW = math.sin(wobT) * 0.08
        dTmr = dTmr - dt
        if dTmr <= 0 then
            dTgt = (math.random() * 2 - 1) * 0.06
            dTmr = 0.4 + math.random() * 0.7
        end
        dC = dC + (dTgt - dC) * 0.04
        wobS = wobS + dt * 4.2
        local step = (math.abs(math.sin(wobS))^3) * 0.03 * ((math.floor(wobS/math.pi)%2==0) and 1 or -1)
        local wobble = sinW + dC + step

        -- Итоговая скорость
        local spd = 18 * speedMult
        bv.Velocity = Vector3.new(
            dir.X * spd,
            vy + wobble * 4 + resVel,
            dir.Z * spd
        )

        -- Поворот
        if dir.Magnitude > 0.05 then
            bg.CFrame = CFrame.lookAt(Root.Position, Root.Position + dir)
        end
    end)
end

