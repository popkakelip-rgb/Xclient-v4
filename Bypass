local function findTool(n)
    local ch=LP.Character;local bp=LP:FindFirstChild("Backpack")
    if ch then for _,v in ipairs(ch:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find(n:lower()) then return v,true end end end
    if bp then for _,v in ipairs(bp:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find(n:lower()) then return v,false end end end
    return nil,false
end
local function runSpeed(mode)
    stopSpeed()
    if mode=="collision" then
        speedConn=RunSvc.Heartbeat:Connect(function()
            local ch=LP.Character;local rt=ch and ch:FindFirstChild("HumanoidRootPart");if not rt then return end
            for _,pl in ipairs(Players:GetPlayers()) do
                if pl==LP then continue end
                local c2=pl.Character;if not c2 then continue end
                local r2=c2:FindFirstChild("HumanoidRootPart");if not r2 then continue end
                local diff=rt.Position-r2.Position
                if diff.Magnitude<spCfg.collision.r then
                    local d=diff.Magnitude>.01 and diff.Unit or Vector3.new(0,0,1)
                    local bv=rt:FindFirstChild("xcSpBV") or mkBV(rt,"xcSpBV")
                    bv.Velocity=d*spCfg.collision.s+Vector3.new(0,10,0)
                    task.delay(.35,function() if bv and bv.Parent then bv:Destroy() end end)
                end
            end
        end)
        notify("Speed","Collision",TC)
    elseif mode=="minijump" then
        local t2=0
        jumpConn=RunSvc.Heartbeat:Connect(function(dt)
            local ch=LP.Character;local rt=ch and ch:FindFirstChild("HumanoidRootPart");if not rt then return end
            t2=t2+dt
            if t2>=spCfg.minijump.rate then
                t2=0
                local bv=mkBV(rt,"xcMJBV")
                bv.Velocity=Vector3.new(rt.AssemblyLinearVelocity.X,spCfg.minijump.p*1.8,rt.AssemblyLinearVelocity.Z)
                task.delay(.18,function() if bv and bv.Parent then bv:Destroy() end end)
            end
        end)
        notify("Speed","MiniJump",TC)
    elseif mode=="selfpush" then
        local tool,eq=findTool("пощечина")
        if not tool then tool,eq=findTool("slap") end
        if tool then
            local hm=LP.Character and LP.Character:FindFirstChild("Humanoid")
            if hm and not eq then hm:EquipTool(tool);task.wait(.1) end
            pcall(function() tool:Activate() end)
        end
        task.delay(.15,function()
            local rt=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart");if not rt then return end
            local bv=mkBV(rt,"xcPushBV")
            bv.Velocity=rt.CFrame.LookVector*spCfg.selfpush.s+Vector3.new(0,18,0)
            task.delay(.5,function() if bv and bv.Parent then bv:Destroy() end end)
        end)
        notify("Speed","Self Push!",TC)
    end
end

