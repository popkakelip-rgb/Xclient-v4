local function findTool(n)
    local ch=LP.Character;local bp=LP:FindFirstChild("Backpack")
    if ch then for _,v in ipairs(ch:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find(n:lower()) then return v,true end
    end end
    if bp then for _,v in ipairs(bp:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find(n:lower()) then return v,false end
    end end
    return nil,false
end
local function stopSpd()
    if speedConn then speedConn:Disconnect();speedConn=nil end
    if jumpConn then jumpConn:Disconnect();jumpConn=nil end
    local hm=LP.Character and LP.Character:FindFirstChild("Humanoid")
    if hm then hm.WalkSpeed=16 end
end
_G._xcSpeed_stop=stopSpd
local function runSpd(mode)
    stopSpd()
    if mode=="collision" then
        speedConn=RunService.Heartbeat:Connect(function()
            local ch=LP.Character;local rt=ch and ch:FindFirstChild("HumanoidRootPart");if not rt then return end
            for _,pl in ipairs(Players:GetPlayers()) do
                if pl==LP then continue end
                local c2=pl.Character;if not c2 then continue end
                local r2=c2:FindFirstChild("HumanoidRootPart");if not r2 then continue end
                local diff=rt.Position-r2.Position
                if diff.Magnitude<spCfg.collision.radius then
                    local d=diff.Magnitude>.01 and diff.Unit or Vector3.new(0,0,1)
                    rt.AssemblyLinearVelocity=d*spCfg.collision.speed+Vector3.new(0,6,0)
                end
            end
        end)
        notify("Speed","Collision активирован",C.Acc)
    elseif mode=="minijump" then
        local hm=LP.Character and LP.Character:FindFirstChild("Humanoid");if not hm then return end
        hm.JumpPower=spCfg.minijump.power
        local t2=0
        jumpConn=RunService.Heartbeat:Connect(function(dt)
            local h2=LP.Character and LP.Character:FindFirstChild("Humanoid");if not h2 then stopSpd();return end
            t2=t2+dt;if t2>=spCfg.minijump.rate then t2=0;h2.JumpPower=spCfg.minijump.power;h2.Jump=true end
        end)
        notify("Speed","MiniJump активирован",C.Acc)
    elseif mode=="selfpush" then
        local tool,eq=findTool("пощечина")
        if not tool then tool,eq=findTool("slap") end
        if not tool then notify("Self Push","Пощечина не найдена!",Color3.fromRGB(255,80,80));return end
        local hm=LP.Character and LP.Character:FindFirstChild("Humanoid");if not hm then return end
        if not eq then hm:EquipTool(tool);task.wait(.08) end
        pcall(function() tool:Activate() end)
        task.delay(.1,function()
            local rt=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart");if not rt then return end
            local d=rt.CFrame.LookVector
            rt.AssemblyLinearVelocity=Vector3.new(d.X*spCfg.selfpush.speed,14,d.Z*spCfg.selfpush.speed)
        end)
        notify("Speed","Self Push!",C.Acc)
    end
end
_G._xcSpeed_run=runSpd

-- ══ SMARTDODGE ═══════════════════════════════════════════════════
local function getClosestThreat(hrp)
    local closest,vel,predicted;local bestDist=dodgeCfg.Radius
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character then
            local root=p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local v=root.AssemblyLinearVelocity
                local future=root.Position+(v*dodgeCfg.PredictTime)
                local dist=(future-hrp.Position).Magnitude
                if dist<bestDist then
                    bestDist=dist;closest=root;vel=v;predicted=future
                end
            end
        end
    end
    return closest,vel,predicted
end

local function smartDodge(hrp,hum2)
    if not dodgeCfg.Enabled then return end
    if tick()-lastDodge<dodgeCfg.Cooldown then return end
    local enemy,vel,predicted=getClosestThreat(hrp)
    if not(enemy and predicted) then return end
    local away=hrp.Position-predicted
    if away.Magnitude==0 then return end
    away=away.Unit
    local moveDir=hum2.MoveDirection
    local finalDir=away*0.8+moveDir*0.3
    if finalDir.Magnitude>.001 then finalDir=finalDir.Unit else finalDir=away end
    local enemySpeed=vel.Magnitude
    local force=dodgeCfg.BaseForce+(enemySpeed*dodgeCfg.SpeedMultiplier)
    hrp.AssemblyLinearVelocity=Vector3.new(
        finalDir.X*force,
        hrp.AssemblyLinearVelocity.Y,
        finalDir.Z*force
    )
    lastDodge=tick()
end

RunService.Heartbeat:Connect(function()
    if not dodgeCfg.Enabled then return end
    local ch=LP.Character;if not ch then return end
    local hrp=ch:FindFirstChild("HumanoidRootPart")
    local hm=ch:FindFirstChild("Humanoid")
    if not hrp or not hm or hm.Health<=0 then return end
    smartDodge(hrp,hm)
end)

