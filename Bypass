-- ── SmartDodge ────────────────────────────────────────────────────
local function runDodge()
    local ch=LP.Character;local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
    local hm=ch and ch:FindFirstChild("Humanoid");if not hrp or not hm then return end
    if tick()-lastDodge<dCfg.CD then return end
    local bD=dCfg.R;local bF=nil;local bV=Vector3.zero
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl==LP then continue end
        local c2=pl.Character;if not c2 then continue end
        local r2=c2:FindFirstChild("HumanoidRootPart");if not r2 then continue end
        local v2=r2.AssemblyLinearVelocity
        local fut=r2.Position+v2*dCfg.PT
        local d=(fut-hrp.Position).Magnitude
        if d<bD then bD=d;bF=fut;bV=v2 end
    end
    if not bF then return end
    local aw=(hrp.Position-bF);if aw.Magnitude<.01 then return end;aw=aw.Unit
    local fd=(aw*.8+hm.MoveDirection*.3);if fd.Magnitude>.01 then fd=fd.Unit else fd=aw end
    local force=dCfg.BF+bV.Magnitude*dCfg.SM
    local bv=mkBV(hrp,"xcDgBV")
    bv.Velocity=Vector3.new(fd.X*force,hrp.AssemblyLinearVelocity.Y,fd.Z*force)
    task.delay(.22,function() if bv and bv.Parent then bv:Destroy() end end)
    lastDodge=tick()
end
