-- ══════════════════════════════════════════════════════════════════
--  SPEED WALK  —  повышает WalkSpeed персонажа
--  Слайдер 16–100, восстанавливает при отключении
-- ══════════════════════════════════════════════════════════════════
local speedWalkOn  = false
local speedWalkVal = 32
local speedWalkConn= nil

local function stopSpeedWalk()
    speedWalkOn = false
    if speedWalkConn then speedWalkConn:Disconnect(); speedWalkConn = nil end
    local hm = LP.Character and LP.Character:FindFirstChild("Humanoid")
    if hm then hm.WalkSpeed = 16 end
end

local function startSpeedWalk()
    if speedWalkOn then return end; speedWalkOn = true
    speedWalkConn = RunService.Heartbeat:Connect(function()
        local hm = LP.Character and LP.Character:FindFirstChild("Humanoid")
        if hm and speedWalkOn then hm.WalkSpeed = speedWalkVal end
    end)
end

-- ══════════════════════════════════════════════════════════════════
--  HIGH JUMP  —  разовое усиление прыжка через BodyVelocity
--  Каждое нажатие Space добавляет вертикальный импульс
-- ══════════════════════════════════════════════════════════════════
local highJumpOn   = false
local highJumpPow  = 80
local highJumpConn = nil

local function stopHighJump()
    highJumpOn = false
    if highJumpConn then highJumpConn:Disconnect(); highJumpConn = nil end
end

local function startHighJump()
    if highJumpOn then return end; highJumpOn = true
    highJumpConn = UIS.JumpRequest:Connect(function()
        if not highJumpOn then return end
        local ch = LP.Character
        local rt = ch and ch:FindFirstChild("HumanoidRootPart")
        local hm = ch and ch:FindFirstChild("Humanoid")
        if not rt or not hm then return end
        local bvHJ = mkBV(rt, "xcHJBV")
        bvHJ.Velocity = Vector3.new(
            rt.AssemblyLinearVelocity.X,
            highJumpPow,
            rt.AssemblyLinearVelocity.Z
        )
        task.delay(0.3, function()
            if bvHJ and bvHJ.Parent then bvHJ:Destroy() end
        end)
    end)
end

-- ══════════════════════════════════════════════════════════════════
--  FAKE LAG  —  имитирует лаг через искусственные паузы
--  Полезно чтобы избежать некоторых серверных проверок
-- ══════════════════════════════════════════════════════════════════
local fakeLagOn    = false
local fakeLagMs    = 100   -- миллисекунды задержки
local fakeLagConn  = nil
local fakeLagTimer = 0

local function stopFakeLag()
    fakeLagOn = false
    if fakeLagConn then fakeLagConn:Disconnect(); fakeLagConn = nil end
end

local function startFakeLag()
    if fakeLagOn then return end; fakeLagOn = true
    fakeLagConn = RunService.Heartbeat:Connect(function(dt)
        if not fakeLagOn then return end
        fakeLagTimer = fakeLagTimer + dt
        if fakeLagTimer >= (fakeLagMs / 1000) then
            fakeLagTimer = 0
            task.wait(fakeLagMs / 1000)
        end
    end)
end

-- ══════════════════════════════════════════════════════════════════
--  SPIN  —  крутит персонажа по оси Y
-- ══════════════════════════════════════════════════════════════════
local spinOn   = false
local spinSpeed= 8    -- оборотов в секунду (угловая скорость)
local spinConn = nil
local spinAngle= 0

local function stopSpin()
    spinOn = false
    if spinConn then spinConn:Disconnect(); spinConn = nil end
    if spinBG and spinBG.Parent then spinBG:Destroy(); spinBG = nil end
end
spinBG = nil

local function startSpin()
    if spinOn then return end; spinOn = true
    spinBG = Instance.new("BodyAngularVelocity")
    spinBG.Name       = "xcSpinBAV"
    spinBG.MaxTorque  = Vector3.new(0, 1e6, 0)
    spinBG.AngularVelocity = Vector3.new(0, spinSpeed * math.pi * 2, 0)
    spinBG.Parent     = Root
    spinConn = RunService.Heartbeat:Connect(function()
        if not spinOn then stopSpin(); return end
        if not (Root and Root.Parent) then stopSpin(); return end
        -- Поддерживаем скорость вращения
        if spinBG and spinBG.Parent then
            spinBG.AngularVelocity = Vector3.new(0, spinSpeed * math.pi * 2, 0)
        end
    end)
end

