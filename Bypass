-- ══ RESOLVER ═════════════════════════════════════════════════════
local function magicResolver(dt)
    if not resolverOn then resActive=false;resVel=0;return {v=0,m=1} end
    local mp=Root.Position;local found=false;local cl=math.huge
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl==LP then continue end
        local ch=pl.Character;if not ch then continue end
        local r=ch:FindFirstChild("HumanoidRootPart");if not r then continue end
        local d=(r.Position-mp).Magnitude;if d<cl then cl=d end
        if d<=C.RDet then found=true;break end
    end
    if not found then
        for _,obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Humanoid") and obj.Parent~=Char then
                local isPl=false
                for _,pl in ipairs(Players:GetPlayers()) do
                    if pl.Character==obj.Parent then isPl=true;break end
                end
                if isPl then continue end
                local nr=obj.Parent:FindFirstChild("HumanoidRootPart")
                    or obj.Parent:FindFirstChildWhichIsA("BasePart")
                if not nr then continue end
                local d=(nr.Position-mp).Magnitude;if d<cl then cl=d end
                if d<=C.RDet then found=true;break end
            end
        end
    end
    if found then resActive=true
    elseif resActive and cl>C.RSafe then resActive=false end
    local tv=resActive and C.RRise or -C.RSink
    resVel=resVel+(tv-resVel)*C.RLerp
    resVel=math.clamp(resVel,-C.RSink,C.RRise)
    return {v=resVel*dt,m=resActive and C.RBoost or 1}
end

-- ══ MAGIC FLIGHT ══════════════════════════════════════════════════
local function stopFlight()
    if not flying then return end;flying=false
    if flyConn then flyConn:Disconnect();flyConn=nil end
    Root.AssemblyLinearVelocity=Vector3.zero
    Hum.PlatformStand=false;Hum.WalkSpeed=16
    wT=0;sT=0;dC=0;dTgt=0;dTmr=0;resActive=false;resVel=0
    notify("Magic Flight","Отключён",C.TxtD)
end
_G._xcFlight_stop=stopFlight

local function startFlight()
    if flying then return end;flying=true;Hum.PlatformStand=true
    notify("Magic Flight","Активирован",C.Acc)
    local tCF=Root.CFrame
    flyConn=RunService.Heartbeat:Connect(function(dt)
        if Hum.Health<=0 then stopFlight();return end
        local md=Hum.MoveDirection
        local cF=Camera.CFrame
        local cFwd=Vector3.new(cF.LookVector.X,0,cF.LookVector.Z)
        local cR=Vector3.new(cF.RightVector.X,0,cF.RightVector.Z)
        if cFwd.Magnitude>.001 then cFwd=cFwd.Unit end
        if cR.Magnitude>.001 then cR=cR.Unit end
        local dir=Vector3.zero
        if md.Magnitude>.05 then
            local cv=cFwd*(-md.Z)+cR*md.X
            if cv.Magnitude>.001 then dir=cv.Unit end
        end
        local vi=0
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vi=1
        elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
            or UserInputService:IsKeyDown(Enum.KeyCode.RightShift) then vi=-1 end
        local res=magicResolver(dt)
        local spd=C.FlySpeed*res.m
        local vel=Vector3.new(dir.X*spd,vi*C.VertSpeed,dir.Z*spd)
        wT=wT+dt*C.WF;local sinW=math.sin(wT)*C.WA
        dTmr=dTmr-dt
        if dTmr<=0 then
            dTgt=(math.random()*2-1)*C.DA
            dIvl=C.DMin+math.random()*(C.DMax-C.DMin);dTmr=dIvl
        end
        dC=dC+(dTgt-dC)*C.DL
        sT=sT+dt*C.SF
        local sRaw=math.abs(math.sin(sT))
        local sWave=(sRaw^C.SP)*C.SA
        local sSgn=(math.floor(sT/math.pi)%2==0)and 1 or -1
        local wobble=sinW+dC+sWave*sSgn
        local cur=Root.Position
        local nPos=cur+(vel+Vector3.new(0,wobble,0))*dt+Vector3.new(0,res.v,0)
        local nRot
        if dir.Magnitude>.05 then nRot=CFrame.lookAt(nPos,nPos+dir)
        else nRot=CFrame.new(nPos)*CFrame.Angles(0,math.atan2(-cFwd.X,-cFwd.Z),0) end
        tCF=nRot;Root.CFrame=Root.CFrame:Lerp(tCF,C.LerpA)
        Root.AssemblyLinearVelocity=Vector3.zero
    end)
end
_G._xcFlight_start=startFlight

-- ══ DAMAGE FLY ЛОГИКА ════════════════════════════════════════════
local function stopDF()
    dfActive=false
    if dfConn then dfConn:Disconnect();dfConn=nil end
    if not flying then Hum.PlatformStand=false;Hum.WalkSpeed=16
        Root.AssemblyLinearVelocity=Vector3.zero end
end

local function startDF()
    if dfActive then return end
    if dfCharge<=0 then notify("Damage Fly","Заряд кончился! Постой на месте",Color3.fromRGB(255,80,60));return end
    dfActive=true;DfHud.Visible=true
    dfConn=RunService.Heartbeat:Connect(function(dt)
        local ch=LP.Character;local rt=ch and ch:FindFirstChild("HumanoidRootPart")
        local hm=ch and ch:FindFirstChild("Humanoid")
        if not rt or not hm then stopDF();return end
        if hm.Health<=0 then stopDF();return end
        if dfActive then
            dfCharge=math.max(0,dfCharge-C.DFDrain*dt);updateDfHud(dfCharge)
            if dfCharge<=0 then
                dfActive=false;stopDF()
                notify("Damage Fly","Заряд кончился! Постой на месте",Color3.fromRGB(255,80,60));return
            end
            hm.PlatformStand=true
            local md2=hm.MoveDirection
            local cF2=Camera.CFrame
            local cFwd2=Vector3.new(cF2.LookVector.X,0,cF2.LookVector.Z)
            local cR2=Vector3.new(cF2.RightVector.X,0,cF2.RightVector.Z)
            if cFwd2.Magnitude>.001 then cFwd2=cFwd2.Unit end
            if cR2.Magnitude>.001 then cR2=cR2.Unit end
            local dir2=Vector3.zero
            if md2.Magnitude>.05 then
                local cv=cFwd2*(-md2.Z)+cR2*md2.X
                if cv.Magnitude>.001 then dir2=cv.Unit end
            end
            local vi2=0
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vi2=1
            elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
                or UserInputService:IsKeyDown(Enum.KeyCode.RightShift) then vi2=-1 end
            local vel2=Vector3.new(dir2.X*C.FlySpeed,vi2*C.VertSpeed,dir2.Z*C.FlySpeed)
            local nPos2=rt.Position+vel2*dt
            local nRot2
            if dir2.Magnitude>.05 then nRot2=CFrame.lookAt(nPos2,nPos2+dir2)
            else nRot2=CFrame.new(nPos2)*CFrame.Angles(0,math.atan2(-cFwd2.X,-cFwd2.Z),0) end
            rt.CFrame=rt.CFrame:Lerp(nRot2,C.LerpA)
            rt.AssemblyLinearVelocity=Vector3.zero
        else
            hm.PlatformStand=false
            if hm.MoveDirection.Magnitude<0.05 then
                dfCharge=math.min(100,dfCharge+C.DFRegen*dt);updateDfHud(dfCharge)
                if dfCharge>=100 then
                    notify("Damage Fly","Заряд восстановлен!",Color3.fromRGB(100,220,100))
                    if dfConn then dfConn:Disconnect();dfConn=nil end
                end
            end
        end
    end)
end

local function connectDmg()
    if dfDmgConn then dfDmgConn:Disconnect() end
    local prevHp=Hum.Health
    dfDmgConn=Hum.HealthChanged:Connect(function(hp)
        if not dfOn then return end
        if hp<prevHp then startDF() end
        prevHp=hp
    end)
end

local function setDF(v)
    dfOn=v
    if v then DfHud.Visible=true;updateDfHud(dfCharge);connectDmg()
        notify("Damage Fly","Активирован — получи урон",Color3.fromRGB(255,140,50))
    else stopDF()
        if dfDmgConn then dfDmgConn:Disconnect();dfDmgConn=nil end
        DfHud.Visible=false;notify("Damage Fly","Отключён",C.TxtD)
    end
end
_G._xcDF_set=setDF
