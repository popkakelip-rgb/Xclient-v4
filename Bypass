local function Notify(title, text)
    local n = Instance.new("Frame", NotifFrame)
    n.Size = UDim2.new(0, 240, 0, 65)
    n.BackgroundColor3 = Config.Bg
    Instance.new("UICorner", n)
    Instance.new("UIStroke", n).Color = Config.Accent
    
    local tl = Instance.new("TextLabel", n)
    tl.Text = "  " .. title; tl.Size = UDim2.new(1,0,0,30); tl.Font = Enum.Font.GothamBold; tl.TextColor3 = Config.Accent; tl.TextSize = 14; tl.BackgroundTransparency = 1; tl.TextXAlignment = "Left"
    
    local tx = Instance.new("TextLabel", n)
    tx.Text = "  " .. text; tx.Position = UDim2.new(0,0,0.4,0); tx.Size = UDim2.new(1,0,0,30); tx.Font = Enum.Font.Gotham; tx.TextColor3 = Color3.new(1,1,1); tx.TextSize = 12; tx.BackgroundTransparency = 1; tx.TextXAlignment = "Left"
    
    task.delay(4, function() 
        TweenService:Create(n, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
        TweenService:Create(tl, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        TweenService:Create(tx, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        task.wait(0.5)
        n:Destroy() 
    end)
end

