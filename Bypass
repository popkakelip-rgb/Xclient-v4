local function checkNearbyEntities()
 if not rootPart then return false, math.huge end
 
 local myPosition = rootPart.Position
 local closestDistance = math.huge
 local foundEntity = false
 
 for _, otherPlayer in ipairs(Players:GetPlayers()) do
  if otherPlayer ~= player and otherPlayer.Character then
   local otherRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
   if otherRoot then
    local dist = (otherRoot.Position - myPosition).Magnitude
    if dist < closestDistance then
     closestDistance = dist
     foundEntity = true
    end
   end
  end
 end
 
 for _, desc in ipairs(workspace:GetDescendants()) do
  if desc:IsA("Humanoid") and desc ~= humanoid then
   local npcRoot = desc.Parent:FindFirstChild("HumanoidRootPart")
   if npcRoot then
    local dist = (npcRoot.Position - myPosition).Magnitude
    if dist < closestDistance then
     closestDistance = dist
     foundEntity = true
    end
   end
  end
 end
 
 return foundEntity, closestDistance
end

-- ═══════════════════════════════════════════════════════════════
-- FLIGHT SYSTEM
-- ═══════════════════════════════════════════════════════════════
local function enableFlight()
 if isFlying then return end
 isFlying = true
 hoverTime = 0
 currentSpeed = 0
 tiltAngle = 0
 breathePhase = 0
 
 nextRandomTime = 0
 randomOffset = 0
 targetRandomOffset = 0
 microDropTimer = 0
 microDropOffset = 0
 resolverTargetHeight = 0
 resolverCurrentBoost = 1
 
 bodyGyro = Instance.new("BodyGyro")
 bodyGyro.MaxTorque = Vector3.new(400000, 400000, 400000)
 bodyGyro.P = 15000
 bodyGyro.D = 800
 bodyGyro.Parent = rootPart
 
 humanoid.PlatformStand = true
 
 flightConnection = RunService.Heartbeat:Connect(function(deltaTime)
  if not isFlying or not rootPart then return end
  
  local targetResolverHeight = 0
  local targetSpeedBoost = 1
  
  if isMagicResolverEnabled then
   local foundEntity, closestDistance = checkNearbyEntities()
   if foundEntity and closestDistance < RESOLVER_DETECT_RADIUS then
    local urgency = 1 - (closestDistance / RESOLVER_DETECT_RADIUS)
    targetResolverHeight = RESOLVER_LIFT_HEIGHT * urgency
    targetSpeedBoost = 1 + (RESOLVER_SPEED_BOOST - 1) * urgency
   end
  end
  
  resolverTargetHeight = resolverTargetHeight + (targetResolverHeight - resolverTargetHeight) * 0.04
  resolverCurrentBoost = resolverCurrentBoost + (targetSpeedBoost - resolverCurrentBoost) * 0.06
  
  local camera = workspace.CurrentCamera
  local cameraLook = camera.CFrame.LookVector
  local cameraRight = camera.CFrame.RightVector
  local moveDirection = humanoid.MoveDirection
  local horizontalMove = Vector3.zero
  local isMoving = moveDirection.Magnitude > 0.1
  
  if isMoving then
   local flatLook = Vector3.new(cameraLook.X, 0, cameraLook.Z).Unit
   local flatRight = Vector3.new(cameraRight.X, 0, cameraRight.Z).Unit
   horizontalMove = (flatLook * moveDirection.Z + flatRight * moveDirection.X)
   targetSpeed = env.FlightSpeed * resolverCurrentBoost
   currentSpeed = currentSpeed + (targetSpeed - currentSpeed) * ACCELERATION
  else
   currentSpeed = currentSpeed * (1 - DECELERATION)
   if currentSpeed < 0.1 then currentSpeed = 0 end
  end
  
  horizontalMove = horizontalMove * currentSpeed
  
  targetTiltAngle = isMoving and TILT_AMOUNT * currentSpeed / env.FlightSpeed or 0
  tiltAngle = tiltAngle + (targetTiltAngle - tiltAngle) * 0.08
  
  local targetVertical = 0
  if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
   targetVertical = VERTICAL_SPEED * env.FlightSpeed
  elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
   targetVertical = -VERTICAL_SPEED * env.FlightSpeed
  end
  
  if resolverTargetHeight > 0.1 then
   targetVertical = targetVertical + resolverTargetHeight * 3
  end
  
  verticalVelocity = verticalVelocity + (targetVertical - verticalVelocity) * 0.12
  
  hoverTime = hoverTime + deltaTime
  breathePhase = breathePhase + deltaTime * HOVER_FREQUENCY * math.pi
  local baseHover = math.sin(breathePhase) * HOVER_AMPLITUDE
  
  nextRandomTime = nextRandomTime - deltaTime
  if nextRandomTime <= 0 then
   nextRandomTime = 0.25 + math.random() * 0.4
   targetRandomOffset = (math.random() - 0.5) * 0.12
  end
  randomOffset = randomOffset + (targetRandomOffset - randomOffset) * 0.06
  
  microDropTimer = microDropTimer - deltaTime
  if microDropTimer <= 0 then
   microDropTimer = 1.2 + math.random() * 2.5
   microDropOffset = -0.1 - math.random() * 0.08
  end
  microDropOffset = microDropOffset + (0 - microDropOffset) * 0.1
  
  windEffect = math.sin(hoverTime * 3.7) * math.cos(hoverTime * 2.3) * 0.025
  local hoverOffset = baseHover + randomOffset + microDropOffset + windEffect
  
  local currentPos = rootPart.Position
  local resolverLift = resolverTargetHeight > 0.5 and resolverTargetHeight * 0.6 or 0
  local velocity = horizontalMove + Vector3.new(0, verticalVelocity + hoverOffset + resolverLift, 0)
  local targetPos = currentPos + velocity * deltaTime
  local targetCFrame = CFrame.new(targetPos)
  
  if horizontalMove.Magnitude > 0.5 then
   local lookAt = currentPos + horizontalMove.Unit
   local baseCFrame = CFrame.new(targetPos, Vector3.new(lookAt.X, targetPos.Y, lookAt.Z))
   targetCFrame = baseCFrame * CFrame.Angles(tiltAngle, 0, 0)
   bodyGyro.CFrame = targetCFrame
  else
   bodyGyro.CFrame = rootPart.CFrame
  end
  
  rootPart.CFrame = rootPart.CFrame:Lerp(targetCFrame, LERP_SPEED)
  rootPart.AssemblyLinearVelocity = Vector3.zero
  rootPart.AssemblyAngularVelocity = Vector3.zero
 end)
 
 updateToggleVisual(flightToggle, true)
 showNotification("Magic Flight", "Flight mode activated", "success")
end

local function disableFlight()
 if not isFlying then return end
 isFlying = false
 verticalVelocity = 0
 currentSpeed = 0
 
 if flightConnection then
  flightConnection:Disconnect()
  flightConnection = nil
 end
 
 if bodyGyro then
  bodyGyro:Destroy()
  bodyGyro = nil
 end
 
 if humanoid then
  humanoid.PlatformStand = false
 end
 
 updateToggleVisual(flightToggle, false)
 showNotification("Magic Flight", "Flight mode deactivated", "warning")
end

local function toggleFlight()
 if isFlying then disableFlight() else enableFlight() end
end

local function toggleMagicResolver()
 isMagicResolverEnabled = not isMagicResolverEnabled
 updateToggleVisual(resolverToggle, isMagicResolverEnabled)
 showNotification("Magic Resolver", isMagicResolverEnabled and "Auto-dodge ON" or "Auto-dodge OFF", isMagicResolverEnabled and "success" or "warning")
 if not isMagicResolverEnabled then
  resolverTargetHeight = 0
  resolverCurrentBoost = 1
 end
end

