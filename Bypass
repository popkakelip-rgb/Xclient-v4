-- ══════════════════════════════════════════════
--  ОПРЕДЕЛЯЕМ РОДИТЕЛЯ ДЛЯ GUI
--  Delta / Xeno / Codex / Fluxus умеют писать
--  в CoreGui — используем его как приоритет,
--  чтобы GUI не сбрасывался при respawn.
--  Если CoreGui недоступен — используем PlayerGui.
-- ══════════════════════════════════════════════
local GuiParent
do
    local ok, coreGui = pcall(function()
        return game:GetService("CoreGui")
    end)
    if ok and coreGui then
        -- Проверяем, разрешает ли эксплойт запись в CoreGui
        local canWrite = pcall(function()
            local t = Instance.new("Frame")
            t.Parent = coreGui
            t:Destroy()
        end)
        GuiParent = canWrite and coreGui
            or game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    else
        GuiParent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    end
end

