-- ══════════════════════════════════════════════════════════════════
--  STRAFE  —  авто Self-Push каждые N студов движения
--  Считает пройденное расстояние и при достижении порога
--  применяет BodyVelocity импульс как Self Push
-- ══════════════════════════════════════════════════════════════════
local strafeOn       = false
local strafeConn     = nil
local strafeDist     = 5     -- студов до следующего буста
local strafePower    = 55    -- сила толчка
local strafeLastPos  = nil
local strafeTraveled = 0

local function stopStrafe()
    strafeOn = false
    if strafeConn then strafeConn:Disconnect(); strafeConn = nil end
    strafeTraveled = 0; strafeLastPos = nil
end

local function startStrafe()
    if strafeOn then return end; strafeOn = true
    strafeLastPos = Root and Root.Position or Vector3.zero
    strafeTraveled = 0

    strafeConn = RunService.Heartbeat:Connect(function(dt)
        if not strafeOn then return end
        local ch = LP.Character
        local rt = ch and ch:FindFirstChild("HumanoidRootPart")
        local hm = ch and ch:FindFirstChild("Humanoid")
        if not rt or not hm then return end

        -- Считаем пройденное расстояние (только горизонтальное)
        local cur = Vector3.new(rt.Position.X, 0, rt.Position.Z)
        if strafeLastPos then
            local delta = (cur - Vector3.new(strafeLastPos.X,0,strafeLastPos.Z)).Magnitude
            strafeTraveled = strafeTraveled + delta
        end
        strafeLastPos = rt.Position

        -- Если прошли достаточно — делаем импульс
        if strafeTraveled >= strafeDist and hm.MoveDirection.Magnitude > 0.05 then
            strafeTraveled = 0
            -- Направление = куда смотрит камера
            local fwd = getCamDir()
            local bvS = mkBV(rt,"xcStrafeBV")
            bvS.Velocity = fwd * strafePower + Vector3.new(0, 12, 0)
            task.delay(0.35, function()
                if bvS and bvS.Parent then bvS:Destroy() end
            end)
        end
    end)
end

