local notifyStack={}
local NW,NH,NG,NRP,NBP=254,48,6,14,14

local function showNotify(title, body, accent)
    accent=accent or Cfg.Accent
    for _,f in ipairs(notifyStack) do
        TweenService:Create(f,TweenInfo.new(.18,Enum.EasingStyle.Quint),{
            Position=UDim2.new(1,-(NW+NRP),1,f.Position.Y.Offset-(NH+NG))
        }):Play()
    end
    local card=Instance.new("Frame",ScreenGui)
    card.Size=UDim2.new(0,NW,0,NH); card.Position=UDim2.new(1,20,1,-(NH+NBP))
    card.BackgroundColor3=Cfg.NotifyBG; card.BorderSizePixel=0; card.ZIndex=90
    corner(4,card); stroke(Cfg.Border,1,card)
    local bar=Instance.new("Frame",card)
    bar.Size=UDim2.new(0,2,1,0); bar.BackgroundColor3=accent
    bar.BorderSizePixel=0; bar.ZIndex=91; corner(3,bar)
    local tl=Instance.new("TextLabel",card)
    tl.Size=UDim2.new(1,-14,0,20); tl.Position=UDim2.new(0,11,0,7)
    tl.BackgroundTransparency=1; tl.Text=title; tl.TextColor3=Cfg.White
    tl.TextSize=12; tl.Font=Enum.Font.GothamBold
    tl.TextXAlignment=Enum.TextXAlignment.Left; tl.ZIndex=91
    local bl=Instance.new("TextLabel",card)
    bl.Size=UDim2.new(1,-14,0,16); bl.Position=UDim2.new(0,11,0,27)
    bl.BackgroundTransparency=1; bl.Text=body; bl.TextColor3=Cfg.TextDim
    bl.TextSize=10; bl.Font=Enum.Font.Gotham
    bl.TextXAlignment=Enum.TextXAlignment.Left; bl.ZIndex=91
    TweenService:Create(card,TweenInfo.new(.28,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{
        Position=UDim2.new(1,-(NW+NRP),1,-(NH+NBP))
    }):Play()
    table.insert(notifyStack,card)
    task.delay(3.5,function()
        for i,c in ipairs(notifyStack) do if c==card then table.remove(notifyStack,i) break end end
        if not(card and card.Parent) then return end
        TweenService:Create(card,TweenInfo.new(.22,Enum.EasingStyle.Quint,Enum.EasingDirection.In),{
            Position=UDim2.new(1,22,1,card.Position.Y.Offset)
        }):Play()
        task.wait(.25); if card and card.Parent then card:Destroy() end
    end)
end

