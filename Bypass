local env = getgenv and getgenv() or _G

-- Защита от повторного запуска
if env.XClientLoaded then
	warn("[XCLIENT] Script already running! Restart game to reload.")
	return
end
env.XClientLoaded = true

-- Совместимость task библиотеки
local taskLib = task or {
	wait = function(t) return wait(t or 0) end,
	spawn = function(f) return coroutine.wrap(f)() end,
	delay = function(t, f) delay(t, f) end
}

-- Безопасный вызов функций
local function safeCall(func, ...)
	local success, result = pcall(func, ...)
	if not success then
		warn("[XCLIENT] Error: " .. tostring(result))
	end
	return success, result
end

