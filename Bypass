local function cr(r,p) local c=Instance.new("UICorner",p);c.CornerRadius=UDim.new(0,r);return c end
local function mkSt(col,t,p) local s=Instance.new("UIStroke",p);s.Color=col;s.Thickness=t;return s end
local function tw(o,t,pr) TweenSvc:Create(o,TweenInfo.new(t,Enum.EasingStyle.Quint),pr):Play() end
local function mkLbl(par,txt,sz,fnt,col,xal)
    local l=Instance.new("TextLabel",par)
    l.BackgroundTransparency=1;l.Text=txt;l.TextSize=sz
    l.Font=fnt or Enum.Font.Gotham;l.TextColor3=col or TXT
    l.TextXAlignment=xal or Enum.TextXAlignment.Center
    l.ZIndex=(par.ZIndex or 10)+1;return l
end
local function mkBV(root,name)
    local bv=Instance.new("BodyVelocity")
    bv.Name=name;bv.MaxForce=Vector3.new(1e5,1e5,1e5)
    bv.Velocity=Vector3.zero;bv.Parent=root;return bv
end
local function mkBG(root,name)
    local bg=Instance.new("BodyGyro")
    bg.Name=name;bg.MaxTorque=Vector3.new(0,1e5,0)
    bg.P=5000;bg.CFrame=root.CFrame;bg.Parent=root;return bg
end
local function getCamDir()
    local cf=Cam.CFrame
    local fwd=Vector3.new(cf.LookVector.X,0,cf.LookVector.Z)
    local rgt=Vector3.new(cf.RightVector.X,0,cf.RightVector.Z)
    if fwd.Magnitude>.001 then fwd=fwd.Unit end
    if rgt.Magnitude>.001 then rgt=rgt.Unit end
    return fwd,rgt
end

-- DRAG (универсальный — для окна и виджетов)
local function makeDraggable(f)
    local dragStart, startPos, dragging = nil, nil, false
    
    f.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = f.Position
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or 
           input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            f.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
                                   startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

