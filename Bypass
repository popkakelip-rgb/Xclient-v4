-- ── Magic Flight (летит по камере автоматически) ──────────────────
local function stopFlight()
    if not flyOn then return end;flyOn=false
    if flyConn then flyConn:Disconnect();flyConn=nil end
    if flyBV and flyBV.Parent then flyBV:Destroy();flyBV=nil end
    if flyBG and flyBG.Parent then flyBG:Destroy();flyBG=nil end
    pcall(function() Hum.PlatformStand=false end)
end
local function startFlight()
    if flyOn then return end;flyOn=true
    flyBV=mkBV(Root,"xcFlyBV");flyBG=mkBG(Root,"xcFlyBG")
    Hum.PlatformStand=true;wobT=0;wobS=0;dC=0;dTgt=0;dTmr=0
    flyConn=RunService.Heartbeat:Connect(function(dt)
        if not(Root and Root.Parent) or Hum.Health<=0 then stopFlight();return end
        local fwd,rgt=getCamDir()
        local md=Hum.MoveDirection
        local dir
        if md.Magnitude>.05 then
            -- Джойстик/WASD: двигаем в нужном направлении относительно камеры
            local v=fwd*(-md.Z)+rgt*md.X
            if v.Magnitude>.001 then dir=v.Unit end
        else
            -- Автоматически летим вперёд по камере
            dir=fwd
        end
        local vy=0
        if UIS:IsKeyDown(Enum.KeyCode.Space) then vy=20
        elseif UIS:IsKeyDown(Enum.KeyCode.LeftShift)
            or UIS:IsKeyDown(Enum.KeyCode.RightShift) then vy=-20 end
        local mult=1
        if resolverOn and resActive then mult=1.35 end
        -- Покачивание
        wobT=wobT+dt*1.6;local sinW=math.sin(wobT)*0.08
        dTmr=dTmr-dt
        if dTmr<=0 then dTgt=(math.random()*2-1)*0.06;dTmr=0.4+math.random()*0.7 end
        dC=dC+(dTgt-dC)*0.04
        wobS=wobS+dt*4.2
        local step=(math.abs(math.sin(wobS))^3)*0.03*((math.floor(wobS/math.pi)%2==0) and 1 or -1)
        local wobble=sinW+dC+step
        flyBV.Velocity=Vector3.new(dir.X*18*mult,vy+wobble*4,dir.Z*18*mult)
        flyBG.CFrame=CFrame.lookAt(Root.Position,Root.Position+dir)
    end)
end

-- ── Resolver (обновляется внутри Flight) ─────────────────────────
local function updateResolver()
    if not resolverOn then resActive=false;resVel=0;return end
    local mp=Root.Position;local found=false;local cl=math.huge
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl==LP then continue end
        local ch=pl.Character;if not ch then continue end
        local r=ch:FindFirstChild("HumanoidRootPart");if not r then continue end
        local d=(r.Position-mp).Magnitude;if d<cl then cl=d end
        if d<=13 then found=true;break end
    end
    if found then resActive=true
    elseif resActive and cl>10 then resActive=false end
end
RunService.Heartbeat:Connect(updateResolver)

-- ── Damage Fly ───────────────────────────────────────────────────
local dfBVObj=nil
local function updateDfHud(p)
    p=math.clamp(p,0,100)
    local col
    if p>60 then col=Color3.fromRGB(math.floor(255*(1-(p-60)/40)),220,80)
    elseif p>30 then col=Color3.fromRGB(255,math.floor(220*((p-30)/30)),30)
    else col=Color3.fromRGB(255,math.floor(80*(p/30)),30) end
    local vis=math.floor(#dfSegs*p/100+.5)
    for i,s in ipairs(dfSegs) do
        s.BackgroundColor3=col;s.BackgroundTransparency=i<=vis and 0 or 0.88
    end
end
local function stopDF()
    dfActive=false
    if dfConn then dfConn:Disconnect();dfConn=nil end
    if dfBVObj and dfBVObj.Parent then dfBVObj:Destroy();dfBVObj=nil end
    if not flyOn then pcall(function() Hum.PlatformStand=false end) end
end
local function startDF()
    if dfActive or dfCharge<=0 then return end
    dfActive=true
    dfBVObj=mkBV(Root,"xcDfBV");Hum.PlatformStand=true
    dfConn=RunService.Heartbeat:Connect(function(dt)
        if not(Root and Root.Parent) or Hum.Health<=0 then stopDF();return end
        if dfActive then
            dfCharge=math.max(0,dfCharge-10*dt);updateDfHud(dfCharge)
            if dfCharge<=0 then
                notify("Damage Fly","Заряд кончился! Постой на месте",Color3.fromRGB(255,80,60))
                dfActive=false;stopDF();return end
            local fwd,rgt=getCamDir()
            local md=Hum.MoveDirection;local dir=fwd
            if md.Magnitude>.05 then
                local v=fwd*(-md.Z)+rgt*md.X;if v.Magnitude>.001 then dir=v.Unit end end
            local vy=0
            if UIS:IsKeyDown(Enum.KeyCode.Space) then vy=16
            elseif UIS:IsKeyDown(Enum.KeyCode.LeftShift) or UIS:IsKeyDown(Enum.KeyCode.RightShift) then vy=-16 end
            dfBVObj.Velocity=Vector3.new(dir.X*18,vy,dir.Z*18)
        else
            Hum.PlatformStand=false
            if dfBVObj then dfBVObj.Velocity=Vector3.zero end
            if Hum.MoveDirection.Magnitude<0.05 then
                dfCharge=math.min(100,dfCharge+5*dt);updateDfHud(dfCharge)
                if dfCharge>=100 then
                    notify("Damage Fly","Заряд восстановлен!",Color3.fromRGB(80,220,100))
                    if dfConn then dfConn:Disconnect();dfConn=nil end
                end
            end
        end
    end)
end
local function connectDmg()
    if dfDmgConn then dfDmgConn:Disconnect() end
    local prev=Hum.Health
    dfDmgConn=Hum.HealthChanged:Connect(function(hp)
        if not dfOn then return end;if hp<prev then startDF() end;prev=hp
    end)
end
local function setDF(v)
    dfOn=v;if v then connectDmg() else stopDF();if dfDmgConn then dfDmgConn:Disconnect();dfDmgConn=nil end end
end

