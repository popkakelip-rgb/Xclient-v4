local function AddToggle(name, key, callback)
	local b = Instance.new("TextButton", Content)
	b.Size = UDim2.new(1, -10, 0, 40)
	b.BackgroundColor3 = Config.Bg
	b.Text = "  " .. name .. " [" .. key .. "]"
	b.Font = Enum.Font.GothamMedium
	b.TextColor3 = Color3.new(1,1,1)
	b.TextSize = 13
	b.TextXAlignment = Enum.TextXAlignment.Left
	Instance.new("UICorner", b)

	local indicator = Instance.new("Frame", b)
	indicator.Size = UDim2.new(0,8,0,8)
	indicator.Position = UDim2.new(1,-20,0.5,-4)
	indicator.BackgroundColor3 = Color3.fromRGB(200,50,50)
	Instance.new("UICorner", indicator)

	b.MouseButton1Click:Connect(function()
		local state = callback()
		TweenService:Create(indicator, TweenInfo.new(0.3), {BackgroundColor3 = state and Color3.fromRGB(50,200,50) or Color3.fromRGB(200,50,50)}):Play()
	end)
end

