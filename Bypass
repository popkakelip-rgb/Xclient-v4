local function updateESP()
    local myPos=Root and Root.Position or Vector3.zero
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl==LP then continue end
        if not espPlayers then
            if playerEsp[pl] and playerEsp[pl].Parent then playerEsp[pl]:Destroy() end
            playerEsp[pl]=nil;continue
        end
        local ch=pl.Character;if not ch then continue end
        local rt=ch:FindFirstChild("HumanoidRootPart");if not rt then continue end
        if not(playerEsp[pl] and playerEsp[pl].Parent) then
            playerEsp[pl]=mkBB(rt,pl.DisplayName,WHT,180,26,3)
        end
        if espShowDist then
            local lb=playerEsp[pl] and playerEsp[pl]:FindFirstChildWhichIsA("TextLabel")
            if lb then
                local d=math.floor((rt.Position-myPos).Magnitude)
                lb.Text=pl.DisplayName.."  ["..d.."st]"
            end
        end
    end
    local anyR=espRarity.Legendary or espRarity.Mythic or espRarity.BrainrotGod or espRarity.Secret
    local anyM=espMut.Gold or espMut.Diamond or espMut.Rainbow or espMut.Bloodrot
    local plots=WS:FindFirstChild("Plots")
    if (anyR or anyM) and plots then
        for _,plot in pairs(plots:GetChildren()) do
            for _,child in pairs(plot:GetDescendants()) do
                if child.Name=="Rarity" and child:IsA("TextLabel") then
                    local rk=RMAP[child.Text];if not rk then continue end
                    local pm=child.Parent and child.Parent.Parent;if not pm then continue end
                    local key=tostring(pm)
                    if espRarity[rk] then
                        if not(rarityEsp[key.."_r"] and rarityEsp[key.."_r"].Parent) then
                            local dn=child.Parent and child.Parent:FindFirstChild("DisplayName")
                            rarityEsp[key.."_r"]=mkBB(pm,dn and dn.Text or child.Text,RCOL[rk],160,44,3)
                        end
                    else if rarityEsp[key.."_r"] and rarityEsp[key.."_r"].Parent then
                        rarityEsp[key.."_r"]:Destroy();rarityEsp[key.."_r"]=nil end end
                    local ml=child.Parent and child.Parent:FindFirstChild("Mutation")
                    if ml and ml:IsA("TextLabel") then
                        local mk=MMAP[ml.Text]
                        if mk and espMut[mk] then
                            if not(rarityEsp[key.."_m"] and rarityEsp[key.."_m"].Parent) then
                                rarityEsp[key.."_m"]=mkBB(pm,ml.Text,MCOL[mk],120,28,6) end
                        else if rarityEsp[key.."_m"] and rarityEsp[key.."_m"].Parent then
                            rarityEsp[key.."_m"]:Destroy();rarityEsp[key.."_m"]=nil end end
                    end
                end
            end
        end
    end
end
