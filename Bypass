local function mkBillboard(adornee, text, col, sx, sy, yo)
    local bb = Instance.new("BillboardGui")
    bb.AlwaysOnTop  = true
    bb.Size         = UDim2.new(0, sx, 0, sy)
    bb.StudsOffset  = Vector3.new(0, yo or 3, 0)
    bb.Adornee      = adornee
    local lb = Instance.new("TextLabel", bb)
    lb.Size = UDim2.new(1,0,1,0)
    lb.BackgroundTransparency = 1
    lb.Text = text
    lb.TextColor3 = col
    lb.TextStrokeColor3 = Color3.new(0,0,0)
    lb.TextStrokeTransparency = 0
    lb.TextScaled = true
    lb.Font = Enum.Font.GothamBold
    bb.Parent = adornee
    return bb
end

local function updateESP()
    -- Players
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl == LP then continue end
        if not espPlayers then
            if playerEsp[pl] and playerEsp[pl].Parent then playerEsp[pl]:Destroy() end
            playerEsp[pl] = nil
            continue
        end
        if playerEsp[pl] and playerEsp[pl].Parent then continue end
        local ch = pl.Character; if not ch then continue end
        local rt = ch:FindFirstChild("HumanoidRootPart"); if not rt then continue end
        playerEsp[pl] = mkBillboard(rt, pl.DisplayName, WHT, 180, 26, 3)
    end

    -- Rarity + Mutation
    local anyR = espRarity.Legendary or espRarity.Mythic or espRarity.BrainrotGod or espRarity.Secret
    local anyM = espMut.Gold or espMut.Diamond or espMut.Rainbow or espMut.Bloodrot
    local plots = Workspace:FindFirstChild("Plots")
    if (anyR or anyM) and plots then
        for _, plot in pairs(plots:GetChildren()) do
            for _, child in pairs(plot:GetDescendants()) do
                if child.Name == "Rarity" and child:IsA("TextLabel") then
                    local rk = RARITY_MAP[child.Text]
                    if not rk then continue end
                    local pMod = child.Parent and child.Parent.Parent
                    if not pMod then continue end
                    local key = tostring(pMod)

                    -- Rarity ESP
                    if espRarity[rk] then
                        if not (rarityEsp[key.."_r"] and rarityEsp[key.."_r"].Parent) then
                            local dn = child.Parent and child.Parent:FindFirstChild("DisplayName")
                            local nm = dn and dn.Text or child.Text
                            rarityEsp[key.."_r"] = mkBillboard(pMod, nm, RARITY_COLOR[rk], 160, 44, 3)
                        end
                    else
                        if rarityEsp[key.."_r"] and rarityEsp[key.."_r"].Parent then
                            rarityEsp[key.."_r"]:Destroy(); rarityEsp[key.."_r"] = nil
                        end
                    end

                    -- Mutation ESP
                    local mutLb = child.Parent and child.Parent:FindFirstChild("Mutation")
                    if mutLb and mutLb:IsA("TextLabel") then
                        local mk = MUT_MAP[mutLb.Text]
                        if mk and espMut[mk] then
                            if not (rarityEsp[key.."_m"] and rarityEsp[key.."_m"].Parent) then
                                rarityEsp[key.."_m"] = mkBillboard(pMod, mutLb.Text, MUT_COLOR[mk], 120, 28, 6)
                            end
                        else
                            if rarityEsp[key.."_m"] and rarityEsp[key.."_m"].Parent then
                                rarityEsp[key.."_m"]:Destroy(); rarityEsp[key.."_m"] = nil
                            end
                        end
                    end
                end
            end
        end
    end
end

task.spawn(function()
    while true do task.wait(0.4); pcall(updateESP) end
end)

