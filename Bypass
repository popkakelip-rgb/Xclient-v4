    if apPart and apPart.Parent then apPart:Destroy();apPart=nil end
end

local function startAutoPlatform()
    if apOn then return end;apOn=true
    -- Создаём платформу прямо под ногами
    apPart=Instance.new("Part")
    apPart.Size=Vector3.new(5,.35,5)
    apPart.Anchored=true;apPart.CanCollide=true
    apPart.Material=Enum.Material.SmoothPlastic
    apPart.Color=Color3.fromRGB(25,25,35)
    -- Позиция: прямо под ступнями (Root - 3.1 = примерно под ногами стоящего)
    apPart.CFrame=CFrame.new(Root.Position.X, Root.Position.Y-3.1, Root.Position.Z)
    apPart.Parent=WS

    apConn=RunService.Heartbeat:Connect(function(dt)
        if not apOn then stopAutoPlatform();return end
        if not(apPart and apPart.Parent) then apOn=false;return end
        local rp=Root.Position
        local pp=apPart.Position
        -- Платформа всегда под ногами по XZ
        local targetX=rp.X; local targetZ=rp.Z
        -- Поднимаем со скоростью apSpeed
        local newY=pp.Y+apSpeed*dt
        -- Но не выше чем (Root.Y - 3.1) чтобы всегда быть под ногами
        local maxY=rp.Y-3.1
        if newY>maxY then newY=maxY end
        apPart.CFrame=CFrame.new(targetX,newY,targetZ)
    end)
end

