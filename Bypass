-- ── SMARTDODGE ────────────────────────────────────────────────────
local function runDodge()
    local ch=LP.Character;local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
    local hm=ch and ch:FindFirstChild("Humanoid");if not hrp or not hm then return end
    if tick()-lastDodge<dCfg.Cooldown then return end
    local bestD=dCfg.Radius;local bestF=nil;local bestV=Vector3.zero
    for _,pl in ipairs(Players:GetPlayers()) do
        if pl==LP then continue end
        local c2=pl.Character;if not c2 then continue end
        local r2=c2:FindFirstChild("HumanoidRootPart");if not r2 then continue end
        local v2=r2.AssemblyLinearVelocity
        local fut=r2.Position+v2*dCfg.PredictTime
        local d=(fut-hrp.Position).Magnitude
        if d<bestD then bestD=d;bestF=fut;bestV=v2 end
    end
    if not bestF then return end
    local away=(hrp.Position-bestF);if away.Magnitude<.01 then return end;away=away.Unit
    local fd=(away*.8+hm.MoveDirection*.3);if fd.Magnitude>.01 then fd=fd.Unit else fd=away end
    local force=dCfg.BaseForce+bestV.Magnitude*dCfg.SpeedMult
    local bvD=mkBV(hrp,"xcDodgeBV")
    bvD.Velocity=Vector3.new(fd.X*force,hrp.AssemblyLinearVelocity.Y,fd.Z*force)
    task.delay(.22,function() if bvD and bvD.Parent then bvD:Destroy() end end)
    lastDodge=tick()
end
RunService.Heartbeat:Connect(function() if dodgeOn then pcall(runDodge) end end)

