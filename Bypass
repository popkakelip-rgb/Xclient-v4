local function GetBypassedVelocity(vel)
    local jitter = Vector3.new(math.random(-5,5)/100, math.sin(tick()*10)*0.2, math.random(-5,5)/100)
    return vel + jitter
end

RunService.RenderStepped:Connect(function()
    if State.Fly then
        local c = player.Character; local hrp = c and c:FindFirstChild("HumanoidRootPart"); local hum = c and c:FindFirstChild("Humanoid")
        if hrp and hum then
            hum:ChangeState(11) -- Anti-Fall State
            local look = Camera.CFrame.LookVector
            local target = Vector3.new(0,0.1,0)
            
            if hum.MoveDirection.Magnitude > 0 then
                target = look * Config.Speed
            end
            
            hrp.Velocity = GetBypassedVelocity(target)
            hrp.RotVelocity = Vector3.new(0,0,0)
            
            -- Anti-Cheat Spoof
            if not hrp:FindFirstChild("X_Force") then
                local bv = Instance.new("BodyVelocity", hrp)
                bv.Name = "X_Force"; bv.MaxForce = Vector3.new(1e6, 1e6, 1e6); bv.Velocity = Vector3.new(0,0,0)
            else
                hrp.X_Force.Velocity = hrp.Velocity
            end
        end
    else
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character.HumanoidRootPart:FindFirstChild("X_Force") then
            player.Character.HumanoidRootPart.X_Force:Destroy()
        end
    end
end)

