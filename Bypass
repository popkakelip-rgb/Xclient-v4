local function findTool(n)
    local ch = LP.Character
    local bp = LP:FindFirstChild("Backpack")
    if ch then
        for _, v in ipairs(ch:GetChildren()) do
            if v:IsA("Tool") and v.Name:lower():find(n:lower()) then return v, true end
        end
    end
    if bp then
        for _, v in ipairs(bp:GetChildren()) do
            if v:IsA("Tool") and v.Name:lower():find(n:lower()) then return v, false end
        end
    end
    return nil, false
end

local function runSpeed(mode)
    stopSpeed()
    speedOn = true
    if mode == "collision" then
        -- BodyVelocity буст при столкновении
        speedConn = RunService.Heartbeat:Connect(function()
            local ch = LP.Character
            local rt = ch and ch:FindFirstChild("HumanoidRootPart")
            if not rt then return end
            for _, pl in ipairs(Players:GetPlayers()) do
                if pl == LP then continue end
                local c2 = pl.Character; if not c2 then continue end
                local r2 = c2:FindFirstChild("HumanoidRootPart"); if not r2 then continue end
                local diff = rt.Position - r2.Position
                if diff.Magnitude < spCfg.collision.radius then
                    local d = diff.Magnitude > 0.01 and diff.Unit or Vector3.new(0,0,1)
                    -- Используем BodyVelocity для буста
                    local bv2 = rt:FindFirstChild("xcSpeedBV")
                    if not bv2 then
                        bv2 = Instance.new("BodyVelocity")
                        bv2.Name     = "xcSpeedBV"
                        bv2.MaxForce = Vector3.new(1e5, 1e5, 1e5)
                        bv2.Parent   = rt
                    end
                    bv2.Velocity = d * spCfg.collision.speed + Vector3.new(0, 8, 0)
                    task.delay(0.3, function()
                        if bv2 and bv2.Parent then bv2:Destroy() end
                    end)
                end
            end
        end)

    elseif mode == "minijump" then
        local hm = LP.Character and LP.Character:FindFirstChild("Humanoid")
        if not hm then return end
        hm.JumpPower = spCfg.minijump.power
        local t2 = 0
        jumpConn = RunService.Heartbeat:Connect(function(dt)
            local h2 = LP.Character and LP.Character:FindFirstChild("Humanoid")
            if not h2 then stopSpeed(); return end
            t2 = t2 + dt
            if t2 >= spCfg.minijump.rate then
                t2 = 0
                h2.JumpPower = spCfg.minijump.power
                h2.Jump = true
            end
        end)

    elseif mode == "selfpush" then
        local tool, eq = findTool("пощечина")
        if not tool then tool, eq = findTool("slap") end
        if not tool then return end
        local hm = LP.Character and LP.Character:FindFirstChild("Humanoid")
        if not hm then return end
        if not eq then hm:EquipTool(tool); task.wait(0.1) end
        pcall(function() tool:Activate() end)
        task.delay(0.15, function()
            local rt = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if not rt then return end
            local bvS = Instance.new("BodyVelocity")
            bvS.Name     = "xcPushBV"
            bvS.MaxForce = Vector3.new(1e5, 1e5, 1e5)
            bvS.Velocity = rt.CFrame.LookVector * spCfg.selfpush.speed + Vector3.new(0, 16, 0)
            bvS.Parent   = rt
            task.delay(0.4, function() if bvS and bvS.Parent then bvS:Destroy() end end)
        end)
    end
end

-- ══════════════════════════════════════════════════════════════════
--  5. SMARTDODGE
-- ══════════════════════════════════════════════════════════════════
local function runDodge()
    local ch = LP.Character
    local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
    local hm  = ch and ch:FindFirstChild("Humanoid")
    if not hrp or not hm then return end
    if tick() - lastDodge < dodgeCfg.Cooldown then return end

    local bestDist = dodgeCfg.Radius
    local bestFuture = nil
    local bestVel = Vector3.zero

    for _, pl in ipairs(Players:GetPlayers()) do
        if pl == LP then continue end
        local c2 = pl.Character; if not c2 then continue end
        local r2 = c2:FindFirstChild("HumanoidRootPart"); if not r2 then continue end
        local v2 = r2.AssemblyLinearVelocity
        local future = r2.Position + v2 * dodgeCfg.PredictTime
        local d = (future - hrp.Position).Magnitude
        if d < bestDist then
            bestDist   = d
            bestFuture = future
            bestVel    = v2
        end
    end

    if not bestFuture then return end

    local away = (hrp.Position - bestFuture)
    if away.Magnitude < 0.01 then return end
    away = away.Unit

    local finalDir = (away * 0.8 + hm.MoveDirection * 0.3)
    if finalDir.Magnitude > 0.01 then finalDir = finalDir.Unit else finalDir = away end

    local force = dodgeCfg.BaseForce + bestVel.Magnitude * dodgeCfg.SpeedMult

    local bvD = Instance.new("BodyVelocity")
    bvD.Name     = "xcDodgeBV"
    bvD.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bvD.Velocity = Vector3.new(finalDir.X * force, hrp.AssemblyLinearVelocity.Y, finalDir.Z * force)
    bvD.Parent   = hrp
    task.delay(0.2, function() if bvD and bvD.Parent then bvD:Destroy() end end)

    lastDodge = tick()
end

RunService.Heartbeat:Connect(function()
    if not dodgeOn then return end
    pcall(runDodge)
end)

