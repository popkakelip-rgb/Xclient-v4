-- ЛОГИКА МОДУЛЕЙ
RunService.Heartbeat:Connect(function()
	local c, hrp, hum = getChar()
	if not hrp or not hum then return end
	
	if Modules.Fly then
		hrp.Velocity = Vector3.new(hum.MoveDirection.X * 25, math.sin(tick()*7)*3, hum.MoveDirection.Z * 25)
	end
	
	if Modules.Dodge then
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				local dist = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
				if dist < 12 then
					local away = (hrp.Position - p.Character.HumanoidRootPart.Position).Unit
					hrp.Velocity = Vector3.new(away.X * 35, 0, away.Z * 35)
				end
			end
		end
	end
end)

