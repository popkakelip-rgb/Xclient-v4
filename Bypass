-- ═══════════════════════════════════════════════════════════════
-- CHARACTER (ИСПРАВЛЕННЫЙ БЛОК)
-- ═══════════════════════════════════════════════════════════════
local player = Players.LocalPlayer
local character = player.Character
if not character or not character.Parent then
    character = player.CharacterAdded:Wait()
end

local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 15)
local rootPart = character:FindFirstChild("HumanoidRootPart") or character:WaitForChild("HumanoidRootPart", 15)

if not humanoid or not rootPart then
    -- Если всё равно не нашло, попробуем еще раз через секунду, а не вылетаем
    taskLib.delay(1, function()
        print("[XCLIENT] Retry loading character...")
        -- Перезапуск логики персонажа
    end)
end

