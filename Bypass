local function mkBV(root,name)
    local bv=Instance.new("BodyVelocity")
    bv.Name=name;bv.MaxForce=Vector3.new(1e5,1e5,1e5)
    bv.Velocity=Vector3.zero;bv.Parent=root;return bv
end
local function mkBG(root,name)
    local bg=Instance.new("BodyGyro")
    bg.Name=name;bg.MaxTorque=Vector3.new(0,1e5,0)
    bg.P=5000;bg.CFrame=root.CFrame;bg.Parent=root;return bg
end
local function getCamDir()
    local cf=Cam.CFrame
    local fwd=Vector3.new(cf.LookVector.X,0,cf.LookVector.Z)
    local rgt=Vector3.new(cf.RightVector.X,0,cf.RightVector.Z)
    if fwd.Magnitude>.001 then fwd=fwd.Unit end
    if rgt.Magnitude>.001 then rgt=rgt.Unit end
    return fwd,rgt
end

