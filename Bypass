local function switchTab(name)
    activeTab=name
    for _,n in ipairs(TABS) do
        local isA=(n==name)
        local d=tabBtns[n]
        tw(d.btn,.15,{BackgroundTransparency=isA and 0.82 or 1,
            BackgroundColor3=isA and Cfg.BG3 or Cfg.BG})
        tw(d.icon,.15,{TextColor3=isA and Cfg.X_BLUE or Cfg.TextDim})
        tw(d.txt,.15,{TextColor3=isA and Cfg.White or Cfg.TextDim})
        tw(tabIndics[n],.15,{BackgroundTransparency=isA and 0 or 1})
        tabPages[n].Visible=isA
    end
end
for _,name in ipairs(TABS) do
    tabBtns[name].btn.MouseButton1Click:Connect(function() switchTab(name) end)
    tabBtns[name].btn.MouseEnter:Connect(function()
        if activeTab~=name then tw(tabBtns[name].txt,.1,{TextColor3=Cfg.TextMid}) end
    end)
    tabBtns[name].btn.MouseLeave:Connect(function()
        if activeTab~=name then tw(tabBtns[name].txt,.1,{TextColor3=Cfg.TextDim}) end
    end)
