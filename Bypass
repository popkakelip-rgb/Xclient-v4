local keybinds   = {}   -- { [Enum.KeyCode.X] = {label, fn} }
local keybindOn  = true

local function registerKeybind(keyCode, label, fn)
    keybinds[keyCode] = {label = label, fn = fn}
end

local function removeKeybind(keyCode)
    keybinds[keyCode] = nil
end

