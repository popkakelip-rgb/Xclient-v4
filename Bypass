local dfSegs = {}  -- заполнится при создании HUD
local function updateDfHud(p)
    p = math.clamp(p, 0, 100)
    local col
    if p > 60 then col = Color3.fromRGB(math.floor(255*(1-(p-60)/40)), 220, 80)
    elseif p > 30 then col = Color3.fromRGB(255, math.floor(220*((p-30)/30)), 30)
    else col = Color3.fromRGB(255, math.floor(80*(p/30)), 30) end
    local vis = math.floor(#dfSegs * p / 100 + .5)
    for i, s in ipairs(dfSegs) do
        s.BackgroundColor3 = col
        s.BackgroundTransparency = i <= vis and 0 or 0.88
    end
end

local function stopDF()
    dfActive = false
    if dfConn then dfConn:Disconnect(); dfConn = nil end
    if not flyOn then pcall(function() Hum.PlatformStand = false end) end
end

local function startDF()
    if dfActive then return end
    if dfCharge <= 0 then return end
    dfActive = true

    local dfBV = Instance.new("BodyVelocity")
    dfBV.Name     = "xcDfBV"
    dfBV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    dfBV.Velocity = Vector3.zero
    dfBV.Parent   = Root
    Hum.PlatformStand = true

    dfConn = RunService.Heartbeat:Connect(function(dt)
        if not (Root and Root.Parent) then stopDF(); return end
        if Hum.Health <= 0 then stopDF(); return end

        if dfActive then
            dfCharge = math.max(0, dfCharge - 10 * dt)
            updateDfHud(dfCharge)
            if dfCharge <= 0 then dfActive = false; dfBV:Destroy(); stopDF(); return end

            local cf2 = Cam.CFrame
            local fwd2 = Vector3.new(cf2.LookVector.X, 0, cf2.LookVector.Z)
            local rgt2 = Vector3.new(cf2.RightVector.X, 0, cf2.RightVector.Z)
            if fwd2.Magnitude > 0.001 then fwd2 = fwd2.Unit end
            if rgt2.Magnitude > 0.001 then rgt2 = rgt2.Unit end
            local md2 = Hum.MoveDirection
            local dir2 = Vector3.zero
            if md2.Magnitude > 0.05 then
                local v = fwd2 * (-md2.Z) + rgt2 * md2.X
                if v.Magnitude > 0.001 then dir2 = v.Unit end
            end
            local vy2 = 0
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vy2 = 16
            elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
                or UserInputService:IsKeyDown(Enum.KeyCode.RightShift) then vy2 = -16 end
            dfBV.Velocity = Vector3.new(dir2.X * 18, vy2, dir2.Z * 18)
        else
            Hum.PlatformStand = false
            dfBV.Velocity = Vector3.zero
            if Hum.MoveDirection.Magnitude < 0.05 then
                dfCharge = math.min(100, dfCharge + 5 * dt)
                updateDfHud(dfCharge)
            end
        end
    end)
end

local function connectDmg()
    if dfDmgConn then dfDmgConn:Disconnect() end
    local prevHp = Hum.Health
    dfDmgConn = Hum.HealthChanged:Connect(function(hp)
        if not dfOn then return end
        if hp < prevHp then startDF() end
        prevHp = hp
    end)
end

local function setDF(v)
    dfOn = v
    if v then connectDmg()
    else
        stopDF()
        if dfDmgConn then dfDmgConn:Disconnect(); dfDmgConn = nil end
    end
end

