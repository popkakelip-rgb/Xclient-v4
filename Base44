local function getClosestThreat(hrp)
    local closest, vel, predicted
    local bestDist = dodgeRadius
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local v = root.AssemblyLinearVelocity
                local pt = dodgePredictTime * 0.1
                local future = root.Position + (v * pt)
                local dist = (future - hrp.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    closest = root
                    vel = v
                    predicted = future
                end
            end
        end
    end
    return closest, vel, predicted, bestDist
end

local function doSmartDodge()
    if not rootPart or not humanoid then return end
    local cd = dodgeCooldown * 0.01
    if tick() - lastDodge < cd then return end
    local enemy, vel, predicted, dist = getClosestThreat(rootPart)
    if not enemy or not predicted then return end
    local away = (rootPart.Position - predicted)
    if away.Magnitude == 0 then return end
    away = away.Unit
    local moveDir = humanoid.MoveDirection
    local finalDir = (away * 0.8 + moveDir * 0.3)
    if finalDir.Magnitude > 0 then finalDir = finalDir.Unit end
    local enemySpeed = vel.Magnitude
    local force = dodgeBaseForce + (enemySpeed * 0.45)
    rootPart.AssemblyLinearVelocity = Vector3.new(
        finalDir.X * force,
        rootPart.AssemblyLinearVelocity.Y,
        finalDir.Z * force
    )
    lastDodge = tick()
end

