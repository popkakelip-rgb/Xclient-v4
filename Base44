    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
end

--- Включает режим полёта
local function enableFlight()
    if isFlying then return end
    isFlying = true
    bobTime = 0

    -- Обновляем ссылки на персонажа (на случай респавна)
    character = player.Character
    if not character then return end
    humanoid = character:FindFirstChildOfClass("Humanoid")
    rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end

    -- Отключаем стандартное падение
    humanoid.PlatformStand = true

    -- Создаём силы для полёта
    createFlightForces()

    -- Инициализируем таймеры рандомизации
    noiseTimer = 0
    noiseInterval = NOISE_INTERVAL_MIN + math.random() * (NOISE_INTERVAL_MAX - NOISE_INTERVAL_MIN)
    noiseTargetY = 0
    noiseCurY = 0
    noiseTargetX = 0
    noiseCurX = 0
    dropTimer = 0
    dropInterval = DROP_INTERVAL_MIN + math.random() * (DROP_INTERVAL_MAX - DROP_INTERVAL_MIN)
    isDroppingMicro = false
    dropForce = 0
    dropDurationTimer = 0
    surgeTimer = 0
    surgeInterval = SURGE_INTERVAL_MIN + math.random() * (SURGE_INTERVAL_MAX - SURGE_INTERVAL_MIN)
    isSurging = false
    surgeForce = 0
    surgeDurationTimer = 0
    tiltTimer = 0
    tiltInterval = TILT_INTERVAL_MIN + math.random() * (TILT_INTERVAL_MAX - TILT_INTERVAL_MIN)
    tiltTargetX = 0
    tiltTargetZ = 0
    tiltCurX = 0
    tiltCurZ = 0

    -- ─────────────────────────────────────────────────────
    -- Главный цикл полёта (RunService.Heartbeat)
    -- ─────────────────────────────────────────────────────
    heartbeatConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not isFlying then return end
        if not rootPart or not rootPart.Parent then
            disableFlight()
            return
        end

        -- 1. Обнуляем внешние силы
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

        -- 2. Камера — направление полёта по взгляду игрока
        local camera = workspace.CurrentCamera
        local camCFrame = camera.CFrame
        -- Горизонтальный вектор по взгляду камеры (игнорируем вертикаль)
        local camLook = camCFrame.LookVector
        local flatLook = Vector3.new(camLook.X, 0, camLook.Z)
        if flatLook.Magnitude > 0.01 then
            flatLook = flatLook.Unit
        end
        local camRight = Vector3.new(camCFrame.RightVector.X, 0, camCFrame.RightVector.Z)
        if camRight.Magnitude > 0.01 then
            camRight = camRight.Unit
        end

        -- Движение джойстика/клавиатур → переводим в систему камеры
        local rawMove = humanoid.MoveDirection
        local speed = _G.FlightSpeed or 16
        local camRelativeMove = Vector3.new(0, 0, 0)
        if rawMove.Magnitude > 0.01 then
            -- Проецируем rawMove на оси камеры
            local forward = flatLook * (-rawMove.Z)  -- вперёд/назад
            local strafe  = camRight  * rawMove.X    -- влево/вправо
            camRelativeMove = (forward + strafe)
            if camRelativeMove.Magnitude > 1 then
                camRelativeMove = camRelativeMove.Unit
            end
        end

        -- 3. Горизонтальное движение (по камере)
        local horizontalVelocity = camRelativeMove * speed

        -- 4. Вертикальное движение (подъём пробелом)
        local verticalVelocity = 0
        if isAscending then
            verticalVelocity = speed * 0.75
        end

        -- ─────────────────────────────────────────────────
        -- MAGIC RESOLVER — автоподъём при близости персонажей
        -- ─────────────────────────────────────────────────
        local resolverExtra = 0
        if isMagicResolverOn then
            local dist = getClosestCharacterDistance(RESOLVER_RISE_RADIUS)
            if dist <= RESOLVER_RISE_RADIUS then
                -- Рядом кто-то есть → поднимаемся
                resolverRising = true
            elseif dist >= RESOLVER_DROP_RADIUS + 2 then
                -- Достаточно далеко → плавно опускаемся
                resolverRising = false
            end
            -- Плавный Lerp скорости подъёма/опускания
            local targetLift = resolverRising and (speed * RESOLVER_RISE_SPEED) or -2.5
            resolverLiftVelocity = resolverLiftVelocity + (targetLift - resolverLiftVelocity) * (3.5 * deltaTime)
            resolverExtra = resolverLiftVelocity
        else
            resolverLiftVelocity = 0
        end

        -- ─────────────────────────────────────────────────
        -- 5. СЛУЧАЙНЫЙ ШУМ (плавная интерполяция к новым целям)
        -- ─────────────────────────────────────────────────
        bobTime = bobTime + deltaTime
        noiseTimer = noiseTimer + deltaTime

        if noiseTimer >= noiseInterval then
            -- Выбираем новые случайные цели
            noiseTargetY = (math.random() * 2 - 1) * 0.35   -- от -0.35 до +0.35 studs/s
            noiseTargetX = (math.random() * 2 - 1) * 0.18   -- горизонтальный микросдвиг
            noiseTimer = 0
            -- Следующий интервал тоже случайный
            noiseInterval = NOISE_INTERVAL_MIN + math.random() * (NOISE_INTERVAL_MAX - NOISE_INTERVAL_MIN)
        end

        -- Плавно тянемся к целевым значениям (Lerp)
        local lerpSpeed = 2.5 * deltaTime
        noiseCurY = noiseCurY + (noiseTargetY - noiseCurY) * lerpSpeed
        noiseCurX = noiseCurX + (noiseTargetX - noiseCurX) * lerpSpeed

        -- ─────────────────────────────────────────────────
        -- 6. МИКРОПАДЕНИЯ (случайные кратковременные провалы)
        -- ─────────────────────────────────────────────────
        local dropOffset = 0

        if not isDroppingMicro then
            dropTimer = dropTimer + deltaTime
            if dropTimer >= dropInterval then
                -- Начинаем микропадение
                isDroppingMicro = true
                dropForce = DROP_STRENGTH_MIN + math.random() * (DROP_STRENGTH_MAX - DROP_STRENGTH_MIN)
                dropDurationTimer = 0
                dropTimer = 0
                -- Следующее падение — снова случайно
                dropInterval = DROP_INTERVAL_MIN + math.random() * (DROP_INTERVAL_MAX - DROP_INTERVAL_MIN)
            end
        else
            -- Активное падение: резкий провал вниз
            dropDurationTimer = dropDurationTimer + deltaTime
            local progress = dropDurationTimer / DROP_DURATION  -- от 0 до 1

            if progress < 0.5 then
                -- Первая половина: падаем вниз
                dropOffset = -dropForce * math.sin(progress * math.pi)
            else
                -- Вторая половина: плавно возвращаемся
                dropOffset = -dropForce * math.sin(progress * math.pi) * 0.4
            end

            if dropDurationTimer >= DROP_DURATION then
                isDroppingMicro = false
                dropOffset = 0
            end
        end

        -- ─────────────────────────────────────────────────
        -- 7. СИНУСОИДАЛЬНОЕ ПОКАЧИВАНИЕ (micro-steps, 3 волны)
        -- ─────────────────────────────────────────────────
        -- Три синуса с разными частотами складываются в органичное "дыхание"
        local waveY = math.sin(bobTime * WAVE_FREQ_1) * WAVE_AMP_1
                    + math.sin(bobTime * WAVE_FREQ_2) * WAVE_AMP_2
                    + math.sin(bobTime * WAVE_FREQ_3) * WAVE_AMP_3

        -- ─────────────────────────────────────────────────
        -- 8. СЛУЧАЙНЫЕ РЫВКИ (micro-surges вперёд/назад)
        -- ─────────────────────────────────────────────────
        local surgeOffset = Vector3.new(0, 0, 0)

        if not isSurging then
            surgeTimer = surgeTimer + deltaTime
            if surgeTimer >= surgeInterval then
                isSurging = true
                -- Случайная сила: + вперёд или - назад
                local sign = (math.random(0, 1) == 0) and 1 or -1
                surgeForce = sign * (SURGE_STRENGTH_MIN + math.random() * (SURGE_STRENGTH_MAX - SURGE_STRENGTH_MIN))
                surgeDurationTimer = 0
                surgeTimer = 0
                surgeInterval = SURGE_INTERVAL_MIN + math.random() * (SURGE_INTERVAL_MAX - SURGE_INTERVAL_MIN)
            end
        else
            surgeDurationTimer = surgeDurationTimer + deltaTime
            local sp = surgeDurationTimer / SURGE_DURATION
            -- Синус-огибающая: плавное ускорение и затухание
            local surgeStrength = surgeForce * math.sin(sp * math.pi)
            -- Рывок направлен вперёд по взгляду персонажа
            local lookVec = rootPart.CFrame.LookVector
            surgeOffset = lookVec * surgeStrength
            if surgeDurationTimer >= SURGE_DURATION then
                isSurging = false
                surgeOffset = Vector3.new(0, 0, 0)
            end
        end

        -- ─────────────────────────────────────────────────
        -- 9. СЛУЧАЙНЫЙ НАКЛОН ТЕЛА (body tilt)
        -- ─────────────────────────────────────────────────
        tiltTimer = tiltTimer + deltaTime
        if tiltTimer >= tiltInterval then
            tiltTargetX = (math.random() * 2 - 1) * TILT_MAX_ANGLE
            tiltTargetZ = (math.random() * 2 - 1) * TILT_MAX_ANGLE
            tiltTimer = 0
            tiltInterval = TILT_INTERVAL_MIN + math.random() * (TILT_INTERVAL_MAX - TILT_INTERVAL_MIN)
        end
        -- Плавный Lerp к целевому наклону
        local tiltLerp = 1.2 * deltaTime
        tiltCurX = tiltCurX + (tiltTargetX - tiltCurX) * tiltLerp
        tiltCurZ = tiltCurZ + (tiltTargetZ - tiltCurZ) * tiltLerp

        -- ─────────────────────────────────────────────────
        -- 10. Итоговая скорость (всё вместе)
        -- ─────────────────────────────────────────────────
        local rightVec = rootPart.CFrame.RightVector
        local sideNoise = rightVec * noiseCurX

        bodyVelocity.Velocity = Vector3.new(
            horizontalVelocity.X + sideNoise.X + surgeOffset.X,
            verticalVelocity + noiseCurY + dropOffset + waveY + resolverExtra,
            horizontalVelocity.Z + sideNoise.Z + surgeOffset.Z
        )

        -- 11. Поворот по камере + случайный наклон тела
        if camRelativeMove.Magnitude > 0.1 then
            local lookAt = rootPart.Position + camRelativeMove
            local targetCFrame = CFrame.lookAt(rootPart.Position, lookAt)
                * CFrame.Angles(tiltCurX, 0, tiltCurZ)
            bodyGyro.CFrame = rootPart.CFrame:Lerp(targetCFrame, 0.18)
        else
            -- В покое — лёгкий наклон без поворота
            local idleTilt = rootPart.CFrame * CFrame.Angles(tiltCurX, 0, tiltCurZ)
            bodyGyro.CFrame = rootPart.CFrame:Lerp(idleTilt, 0.08)
        end
    end)

    -- Обновляем UI
    setFlyState(true)
    showNotif("✦  Magic Flight включён", Color3.fromRGB(140, 100, 255))
end

--- Выключает режим полёта
local function disableFlight()
    if not isFlying then return end
    isFlying = false

    -- Отключаем Heartbeat
    if heartbeatConnection then
        heartbeatConnection:Disconnect()
        heartbeatConnection = nil
    end

    -- Удаляем физические объекты
    removeFlightForces()

    -- Возвращаем стандартное поведение
    if humanoid and humanoid.Parent then
        humanoid.PlatformStand = false
    end

    -- Обновляем UI
    setFlyState(false)
    showNotif("✦  Magic Flight выключен", Color3.fromRGB(200, 100, 100))
end

-- Переключатель полёта (кнопка в меню)
flyToggleBtn.Activated:Connect(function()
    if isFlying then
        disableFlight()
    else
        enableFlight()
    end
end)

