        makeSliderRow(p, 71, "Сила", 10, 60, dodgeBaseForce, 2, function(v) dodgeBaseForce = v end)
        makeSliderRow(p, 104, "Cooldown x0.01s", 10, 100, dodgeCooldown, 5, function(v) dodgeCooldown = v end)
    end)
