        if obj:IsA("Humanoid") and obj.Parent ~= character then
            local npcRoot = obj.Parent:FindFirstChild("HumanoidRootPart")
                         or obj.Parent:FindFirstChild("Torso")
                         or obj.Parent:FindFirstChild("UpperTorso")
