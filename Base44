local notifQueue = {}
local notifActive = false

local function showNotif(text, color)
    color = color or Color3.fromRGB(200, 170, 255)
    table.insert(notifQueue, { text = text, color = color })

    if notifActive then return end
    notifActive = true

    local function processQueue()
        while #notifQueue > 0 do
            local item = table.remove(notifQueue, 1)

            local notifFrame = Instance.new("Frame")
            notifFrame.Name = "Notification"
            notifFrame.Size = UDim2.new(0, 260, 0, 42)
            notifFrame.Position = UDim2.new(0, -270, 1, -60)
            notifFrame.AnchorPoint = Vector2.new(0, 1)
            notifFrame.BackgroundColor3 = Color3.fromRGB(8, 8, 12)
            notifFrame.BackgroundTransparency = 0.1
            notifFrame.BorderSizePixel = 0
            notifFrame.ZIndex = 50
            notifFrame.Parent = screenGui

            local nCorner = Instance.new("UICorner")
            nCorner.CornerRadius = UDim.new(0, 8)
            nCorner.Parent = notifFrame

            local nStroke = Instance.new("UIStroke")
            nStroke.Color = item.color
            nStroke.Thickness = 1
            nStroke.Transparency = 0.4
            nStroke.Parent = notifFrame

            -- Цветная полоска слева
            local bar = Instance.new("Frame")
            bar.Size = UDim2.new(0, 3, 1, -8)
            bar.Position = UDim2.new(0, 6, 0.5, 0)
            bar.AnchorPoint = Vector2.new(0, 0.5)
            bar.BackgroundColor3 = item.color
            bar.BorderSizePixel = 0
            bar.ZIndex = 51
            bar.Parent = notifFrame
            local barCorner = Instance.new("UICorner")
            barCorner.CornerRadius = UDim.new(1, 0)
            barCorner.Parent = bar

            local nLabel = Instance.new("TextLabel")
            nLabel.Text = item.text
            nLabel.Font = Enum.Font.GothamSemibold
            nLabel.TextSize = 13
            nLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
            nLabel.BackgroundTransparency = 1
            nLabel.Size = UDim2.new(1, -20, 1, 0)
            nLabel.Position = UDim2.new(0, 16, 0, 0)
            nLabel.TextXAlignment = Enum.TextXAlignment.Left
            nLabel.ZIndex = 51
            nLabel.Parent = notifFrame

            -- Слайд ин
            TweenService:Create(notifFrame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Position = UDim2.new(0, 10, 1, -60)
            }):Play()

            _wait(2.5)

            -- Слайд аут
            local slideOut = TweenService:Create(notifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Position = UDim2.new(0, -270, 1, -60)
            })
            slideOut:Play()
            slideOut.Completed:Connect(function()
                notifFrame:Destroy()
            end)

            _wait(0.35)
        end
        notifActive = false
    end

    _spawn(processQueue)
end

