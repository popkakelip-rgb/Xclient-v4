        if not rootPart or not rootPart.Parent then dfStopFly() return end
        -- Тратим заряд: 10% в секунду
        damageFlyCharge = math.max(0, damageFlyCharge - dt * 10)
        dfUpdateHud()
        if damageFlyCharge <= 0 then
            dfStopFly()
            if not drainNotifSent then
                drainNotifSent = true
                showNotif("⚡ DamageFly: заряд кончился!", Color3.fromRGB(255, 90, 90))
            end
            return
        end
        -- Полёт по камере
        local cam = workspace.CurrentCamera
        local cl = cam.CFrame.LookVector
        local fl = Vector3.new(cl.X, 0, cl.Z)
        if fl.Magnitude > 0.01 then fl = fl.Unit end
        local cr = Vector3.new(cam.CFrame.RightVector.X, 0, cam.CFrame.RightVector.Z)
        if cr.Magnitude > 0.01 then cr = cr.Unit end
        local rm = humanoid.MoveDirection
        local mv = Vector3.new(0,0,0)
        if rm.Magnitude > 0.01 then
            mv = (fl * (-rm.Z) + cr * rm.X)
            if mv.Magnitude > 1 then mv = mv.Unit end
        end
        damageFlyBV.Velocity = mv * damageFlySpeed
        damageFlyBG.CFrame = rootPart.CFrame:Lerp(CFrame.lookAt(rootPart.Position, rootPart.Position + mv + Vector3.new(0,0.01,0)), 0.2)
    end)
end

