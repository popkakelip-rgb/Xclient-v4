local function findSlapTool()
    local bp = player:FindFirstChildOfClass("Backpack")
    if bp then
        for _, item in ipairs(bp:GetChildren()) do
            local n = item.Name:lower()
            if item:IsA("Tool") and (n:find("slap") or n:find("%d%d%d") or n:find("glove") or n:find("pochechina") or n:find("%p%o%sh")) then
                return item
            end
        end
    end
    if character then
        for _, item in ipairs(character:GetChildren()) do
            if item:IsA("Tool") then return item end
        end
    end
    return nil
end

local function doSelfPush()
    if not rootPart or not humanoid then return end
    local tool = findSlapTool()
    if tool then
        humanoid:EquipTool(tool)
        _wait(0.06)
        for _, v in ipairs(tool:GetDescendants()) do
            if v:IsA("RemoteEvent") then
                pcall(function() v:FireServer() end)
            end
        end
        pcall(function() tool.Activated:Fire() end)
    end
    local angle = math.random() * math.pi * 2
    local dir = Vector3.new(math.cos(angle), 0.4, math.sin(angle))
    rootPart.AssemblyLinearVelocity = dir * selfPushBoost
    pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Ragdoll) end)
end

