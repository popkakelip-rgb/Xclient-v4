--[[
    Открывает меню с анимацией
]]
local function openMenu(menuPanel, openMenuButton)
    if menuOpen then return end
    menuOpen = true

    local tweenInfo = TweenInfo.new(
        TWEEN_DURATION,
        Enum.EasingStyle.Quad,
        Enum.EasingDirection.Out
    )

    local tweenGoal = {
        Size = MENU_SIZE,
        BackgroundTransparency = 0.1
    }

    local tween = TweenService:Create(menuPanel, tweenInfo, tweenGoal)
    tween:Play()
    
    -- Изменяем прозрачность кнопки при открытии
    local buttonTweenGoal = { BackgroundTransparency = 0 }
    local buttonTween = TweenService:Create(openMenuButton, tweenInfo, buttonTweenGoal)
    buttonTween:Play()
end

--[[
    Закрывает меню с анимацией
]]
local function closeMenu(menuPanel, openMenuButton)
    if not menuOpen then return end
    menuOpen = false

    local tweenInfo = TweenInfo.new(
        TWEEN_DURATION,
        Enum.EasingStyle.Quad,
        Enum.EasingDirection.In
    )

    local tweenGoal = {
        Size = UDim2.new(0, 1, 0, 1),
        BackgroundTransparency = 1
    }

    local tween = TweenService:Create(menuPanel, tweenInfo, tweenGoal)
    tween:Play()
    
    -- Восстанавливаем прозрачность кнопки
    local buttonTweenGoal = { BackgroundTransparency = 0.2 }
    local buttonTween = TweenService:Create(openMenuButton, tweenInfo, buttonTweenGoal)
    buttonTween:Play()
end

