    panelButtonGui.Parent = guiTab

    local panelCornerGui = Instance.new("UICorner")
    panelCornerGui.CornerRadius = UDim.new(0, 6)
    panelCornerGui.Parent = panelButtonGui

    csButton.MouseButton1Click:Connect(function()
        guiMode = "CS"
        csButton.BackgroundColor3 = COLOR_ACCENT
        csButton.TextColor3 = Color3.fromRGB(0, 0, 0)
        panelButtonGui.BackgroundColor3 = COLOR_HOVER
        panelButtonGui.TextColor3 = COLOR_TEXT
        showNotification("✓ GUI стиль: CS", COLOR_SUCCESS)
    end)

    panelButtonGui.MouseButton1Click:Connect(function()
        guiMode = "Panel"
        panelButtonGui.BackgroundColor3 = COLOR_ACCENT
        panelButtonGui.TextColor3 = Color3.fromRGB(0, 0, 0)
        csButton.BackgroundColor3 = COLOR_HOVER
        csButton.TextColor3 = COLOR_TEXT
        showNotification("✓ GUI стиль: Panel", COLOR_SUCCESS)
    end)

    -- ФУНКЦИЯ ПЕРЕКЛЮЧЕНИЯ ВКЛАДОК
    local function switchTab(tabName)
        currentTab = tabName
        
        for _, child in ipairs(contentContainer:GetChildren()) do
            if child.Name ~= "ScrollList" then
                child.Visible = false
            end
        end

        if tabName == "MOV" then
            movTab.Visible = true
        elseif tabName == "COM" then
            comTab.Visible = true
        elseif tabName == "VISUAL" then
            visualTab.Visible = true
        elseif tabName == "GUI" then
            guiTab.Visible = true
        end

        for name, tab in pairs(tabButtons) do
            tab.underline.Visible = (name == tabName)
        end
    end

    for tabName, tab in pairs(tabButtons) do
        tab.button.MouseButton1Click:Connect(function()
            switchTab(tabName)
        end)
    end

    return screenGui
end

