-- ИНИЦИАЛИЗАЦИЯ ИНТЕРФЕЙСА
-- ════════════════════════════════════════════════════════════════════════════════

-- Проверяем, существует ли уже меню
local playerGui = localPlayer:WaitForChild("PlayerGui")
if playerGui:FindFirstChild("FlightMenu") then
    playerGui:FindFirstChild("FlightMenu"):Destroy()
end

-- Создаем интерфейс
local screenGui, openMenuButton, menuPanel, toggleButton, toggleIndicator = createFlightMenu()

-- ════════════════════════════════════════════════════════════════════════════════
-- ОБРАБОТЧИКИ СОБЫТИЙ UI
-- ════════════════════════════════════════════════════════════════════════════════

--[[
    Обработчик клика по кнопке открытия меню
]]
openMenuButton.MouseButton1Click:Connect(function()
    if menuOpen then
        closeMenu(menuPanel, openMenuButton)
    else
        openMenu(menuPanel, openMenuButton)
    end
end)

--[[
    Обработчик клика по переключателю полета
]]
toggleButton.MouseButton1Click:Connect(function()
    if isFlying then
        deactivateFlight()
        
        -- Анимация переключателя (выключение)
        local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local tweenGoal = {
            BackgroundColor3 = Color3.fromRGB(50, 50, 50),
            Position = UDim2.new(0, 2, 0.5, -10)
        }
        local indicatorGoal = { BackgroundColor3 = Color3.fromRGB(150, 150, 150) }
        
        local tween1 = TweenService:Create(toggleButton, tweenInfo, tweenGoal)
        local tween2 = TweenService:Create(toggleIndicator, tweenInfo, indicatorGoal)
        
        tween1:Play()
        tween2:Play()
    else
        activateFlight()
        
        -- Анимация переключателя (включение)
        local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local tweenGoal = {
            BackgroundColor3 = Color3.fromRGB(100, 200, 255),
            Position = UDim2.new(0, 23, 0.5, -10)
        }
        local indicatorGoal = { BackgroundColor3 = Color3.fromRGB(100, 200, 255) }
        
        local tween1 = TweenService:Create(toggleButton, tweenInfo, tweenGoal)
        local tween2 = TweenService:Create(toggleIndicator, tweenInfo, indicatorGoal)
        
        tween1:Play()
        tween2:Play()
    end
end)

