local function activateCollision()
    if movementModes.collision.enabled then
        movementModes.collision.enabled = false
        showNotification("✗ Collision отключена", COLOR_ERROR)
        return
    end
    
    movementModes.collision.enabled = true
    showNotification("✓ Collision включена", COLOR_SUCCESS)
    
    local heartbeat
    heartbeat = RunService.Heartbeat:Connect(function(deltaTime)
        if not movementModes.collision.enabled or not character.Parent or humanoid.Health <= 0 then
            heartbeat:Disconnect()
            return
        end
        
        local moveDirection = humanoid.MoveDirection
        if moveDirection.Magnitude > 0 then
            local boostDirection = moveDirection.Unit
            local boostVelocity = boostDirection * movementModes.collision.speed
            rootPart.AssemblyLinearVelocity = rootPart.AssemblyLinearVelocity + boostVelocity * deltaTime
        end
    end)
    
    table.insert(connections, heartbeat)
end

local function activateMiniJump()
    if movementModes.miniJump.enabled then
        movementModes.miniJump.enabled = false
        showNotification("✗ MiniJump отключена", COLOR_ERROR)
        return
    end
    
    movementModes.miniJump.enabled = true
    showNotification("✓ MiniJump включена", COLOR_SUCCESS)
    
    local jumpTimer = 0
    local heartbeat
    heartbeat = RunService.Heartbeat:Connect(function(deltaTime)
        if not movementModes.miniJump.enabled or not character.Parent or humanoid.Health <= 0 then
            heartbeat:Disconnect()
            return
        end
        
        jumpTimer = jumpTimer + deltaTime
        if jumpTimer >= movementModes.miniJump.frequency then
            jumpTimer = 0
            
            local jumpForce = Vector3.new(0, movementModes.miniJump.intensity, 0)
            rootPart.AssemblyLinearVelocity = rootPart.AssemblyLinearVelocity + jumpForce
        end
    end)
    
    table.insert(connections, heartbeat)
end

local function activateSelfPush()
    if movementModes.selfPush.enabled then
        movementModes.selfPush.enabled = false
        showNotification("✗ Self Push отключена", COLOR_ERROR)
        return
    end
    
    local glove = findGloveInInventory("Пощечина")
    if not glove then
        showNotification("✗ Перчатка не найдена в инвентаре!", COLOR_ERROR)
        return
    end
    
    movementModes.selfPush.enabled = true
    showNotification("✓ Self Push включена", COLOR_SUCCESS)
    
    local pushTimer = 0
    local heartbeat
    heartbeat = RunService.Heartbeat:Connect(function(deltaTime)
        if not movementModes.selfPush.enabled or not character.Parent or humanoid.Health <= 0 then
            heartbeat:Disconnect()
            movementModes.selfPush.enabled = false
            return
        end
        
        pushTimer = pushTimer + deltaTime
        
        if pushTimer >= 0.5 then
            pushTimer = 0
            
            local pushDirection = rootPart.CFrame.LookVector
            local pushForce = pushDirection * movementModes.selfPush.speed
            
            rootPart.AssemblyLinearVelocity = rootPart.AssemblyLinearVelocity + pushForce
            
            rootPart.RotVelocity = rootPart.RotVelocity + Vector3.new(
                math.random(-5, 5),
                math.random(-5, 5),
                math.random(-5, 5)
            )
        end
    end)
    
    table.insert(connections, heartbeat)
end

