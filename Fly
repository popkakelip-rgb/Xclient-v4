-- ФУНКЦИИ УПРАВЛЕНИЯ ПОЛЕТОМ
-- ════════════════════════════════════════════════════════════════════════════════

--[[
    Активирует режим полета
]]
local function activateFlight()
    isFlying = true
    
    -- Отключаем стандартное падение
    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Name = "FlightVelocity"
    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVelocity.P = 1250
    bodyVelocity.Parent = rootPart

    -- Отключаем стандартную гравитацию
    local bodyGyro = Instance.new("BodyGyro")
    bodyGyro.Name = "FlightGyro"
    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyGyro.P = 3000
    bodyGyro.Parent = rootPart

    -- Создаем визуальный эффект полета
    createFlightEffect()

    -- Основной цикл полета
    local heartbeatConnection
    heartbeatConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not isFlying or not character.Parent or humanoid.Health <= 0 then
            heartbeatConnection:Disconnect()
            bodyVelocity:Destroy()
            bodyGyro:Destroy()
            isFlying = false
            return
        end

        -- ─────────────────────────────────────────────────────────────────────────
        -- ПОЛУЧЕНИЕ ВХОДНЫХ ДАННЫХ
        -- ─────────────────────────────────────────────────────────────────────────

        local moveDirection = humanoid.MoveDirection -- Работает с мобильным джойстиком
        local verticalInput = spaceKeyPressed and 1 or -1 -- Space = вверх, иначе = вниз

        -- Проверяем сдвиг для быстрого полета
        local isSprinting = false
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or 
           UserInputService:IsKeyDown(Enum.KeyCode.RightShift) then
            isSprinting = true
        end

        -- ─────────────────────────────────────────────────────────────────────────
        -- РЕАЛИСТИЧНАЯ ФИЗИКА ПОЛЕТА
        -- ────────────���────────────────────────────────────────────────────────────

        local currentSpeed = FLIGHT_SPEED * (isSprinting and 1.5 or 1)
        
        -- Направление полета в мировых координатах
        local flightDirection = Vector3.new(moveDirection.X, verticalInput * 0.5, moveDirection.Z)
        
        -- Если нет ввода, применяем гравитацию замедления
        if flightDirection.Magnitude == 0 then
            flightDirection = Vector3.new(0, -1, 0) * 0.3
        else
            flightDirection = flightDirection.Unit
        end

        -- ─────────────────────────────────────────────────────────────────────────
        -- ИМИТАЦИЯ КОЛЕБАНИЙ (ПАРЕНИЕ В ВОЗДУХЕ)
        -- ─────────────────────────────────────────────────────────────────────────

        hoverTime = hoverTime + deltaTime
        local hoverOffset = math.sin(hoverTime * 2) * HOVER_AMPLITUDE

        -- ─────────────────────────────────────────────────────────────────────────
        -- ПРИМЕНЯЕМ ДВИЖЕНИЕ
        -- ─────────────────────────────────────────────────────────────────────────

        local targetVelocity = flightDirection * currentSpeed + Vector3.new(0, hoverOffset, 0)
        
        -- Плавное lerp для реалистичного ускорения
        bodyVelocity.Velocity = bodyVelocity.Velocity:Lerp(targetVelocity, 0.15)
        
        -- Обнуляем ассамблеи для стабильности
        rootPart.AssemblyLinearVelocity = bodyVelocity.Velocity

        -- ─────────────────────────────────────────────────────────────────────────
        -- НАПРАВЛЕНИЕ КАМЕРЫ
        -- ─────────────────────────────────────────────────────────────────────────

        bodyGyro.CFrame = rootPart.CFrame
    end)
end

--[[
    Деактивирует режим полета
]]
local function deactivateFlight()
    isFlying = false
    
    -- Удаляем компоненты полета
    local velocity = rootPart:FindFirstChild("FlightVelocity")
    if velocity then velocity:Destroy() end
    
    local gyro = rootPart:FindFirstChild("FlightGyro")
    if gyro then gyro:Destroy() end
    
    local effect = rootPart:FindFirstChild("FlightEffect")
    if effect then effect:Destroy() end
end

-- ════════════════════════════════════════════════════════════════════════════════
-- ФУНКЦИИ АНИМАЦИИ МЕНЮ
-- ════════════════════════════════════════════════════════════════════════════════

--[[
    Открывает меню с анимацией
]]
local function openMenu(menuPanel, openMenuButton)
    if menuOpen then return end
    menuOpen = true

    local tweenInfo = TweenInfo.new(
        TWEEN_DURATION,
        Enum.EasingStyle.Quad,
        Enum.EasingDirection.Out
    )

    local tweenGoal = {
        Size = MENU_SIZE,
        BackgroundTransparency = 0.1
    }

    local tween = TweenService:Create(menuPanel, tweenInfo, tweenGoal)
    tween:Play()
end

--[[
    Закрывает меню с анимацией
]]
local function closeMenu(menuPanel, openMenuButton)
    if not menuOpen then return end
    menuOpen = false

    local tweenInfo = TweenInfo.new(
        TWEEN_DURATION,
        Enum.EasingStyle.Quad,
        Enum.EasingDirection.In
    )

    local tweenGoal = {
        Size = UDim2.new(0, 1, 0, 1),
        BackgroundTransparency = 1
    }

    local tween = TweenService:Create(menuPanel, tweenInfo, tweenGoal)
    tween:Play()
end

