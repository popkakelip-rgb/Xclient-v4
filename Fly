-- ═════════════════════════════════════════════════════════════════

local function shouldMicroDrop()
    return math.random() < MICRO_DROP_CHANCE
end

local function updateRandomization(deltaTime)
    randomizationTimer = randomizationTimer + deltaTime
    
    if randomizationTimer >= (1 / RANDOMIZATION_FREQUENCY) then
        randomizationTimer = 0
        
        currentRandomX = (math.random() - 0.5) * 2 * MICRO_STEP_INTENSITY
        currentRandomY = (math.random() - 0.5) * 2 * MICRO_STEP_INTENSITY * 0.5
        currentRandomZ = (math.random() - 0.5) * 2 * MICRO_STEP_INTENSITY
    end
end

local function updateMicroDrops(deltaTime)
    if shouldMicroDrop() then
        microDropOffset = microDropOffset - MICRO_DROP_FORCE * deltaTime
    else
        microDropOffset = microDropOffset + MICRO_DROP_FORCE * 0.5 * deltaTime
    end
    
    microDropOffset = math.max(microDropOffset, -MICRO_DROP_FORCE)
    microDropOffset = math.min(microDropOffset, 0)
end

local function createFlightEffect()
    local existingEffect = rootPart:FindFirstChild("FlightEffect")
    if existingEffect then
        existingEffect:Destroy()
    end

    local attachment = Instance.new("Attachment")
    attachment.Name = "FlightEffect"
    attachment.Parent = rootPart

    local particleEmitter = Instance.new("ParticleEmitter")
    particleEmitter.Texture = "rbxasset://textures/particles/sparkles_main.dds"
    particleEmitter.Rate = 20
    particleEmitter.Lifetime = NumberRange.new(0.8)
    particleEmitter.Speed = NumberRange.new(2)
    particleEmitter.Rotation = NumberRange.new(0, 360)
    particleEmitter.Color = ColorSequence.new(COLOR_ACCENT)
    particleEmitter.Transparency = NumberSequence.new(0, 0.5, 1)
    particleEmitter.Parent = attachment

    return attachment
end

