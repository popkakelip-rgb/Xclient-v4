	local function switchTab(tabName)
		for name, container in pairs(tabContainers) do
			container.Visible = (name == tabName)
		end
		for name, button in pairs(tabButtons) do
			button.TextColor3 = (name == tabName) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(140, 140, 150)
		end
		
		local idx = table.find(tabNames, tabName)
		if idx then
			TweenService:Create(tabIndicator, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Position = UDim2.new((idx-1) * 0.25, 0, 1, -2)
			}):Play()
		end
	end
	
	for name, button in pairs(tabButtons) do
		button.MouseButton1Click:Connect(function() switchTab(name) end)
	end

	local function toggleMenu()
		menuOpen = not menuOpen
		
		if not mainFrame or not mainIcon then
			-- Восстанавливаем ссылки если потерялись
			pcall(function()
				local gui = player.PlayerGui:FindFirstChild("FlightSystemGUI")
				if gui then
					mainIcon = gui:FindFirstChild("MainIcon")
					mainFrame = gui:FindFirstChild("MainFrame")
				end
			end)
		end
		
		if not mainFrame or not mainIcon then return end
		
		if menuOpen then
			mainFrame.Visible = true
			TweenService:Create(mainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Size = UDim2.new(0, 280, 0, 420)
			}):Play()
			TweenService:Create(mainIcon, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				BackgroundTransparency = 0
			}):Play()
		else
			TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
				Size = UDim2.new(0, 0, 0, 0)
			}):Play()
