	local function setupHoldButton(button, settingsWindow, toggleCallback)
		local holdStart = 0
		local isButtonHeld = false
		local longPressTriggered = false
		
		button.MouseButton1Down:Connect(function()
			holdStart = tick()
			isButtonHeld = true
			longPressTriggered = false
			
			spawnTask(function()
				while isButtonHeld and not longPressTriggered do
					if tick() - holdStart >= holdThreshold then
						longPressTriggered = true
						settingsWindow.Visible = true
						settingsWindow.Size = UDim2.new(0, 0, 0, 0)
						TweenService:Create(settingsWindow, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
							Size = UDim2.new(0, 260, 0, 180)
						}):Play()
						break
					end
					wait(0.05)
				end
			end)
		end)
		
		button.MouseButton1Up:Connect(function()
			local holdDuration = tick() - holdStart
			isButtonHeld = false
			
			if not longPressTriggered and holdDuration < holdThreshold then
				toggleCallback()
			end
		end)
		
		button.Activated:Connect(function()
			toggleCallback()
		end)
	end

