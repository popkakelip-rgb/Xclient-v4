local function wait(seconds)
	local start = tick()
	repeat RunService.Heartbeat:Wait() until tick() - start >= seconds
end

local function spawnTask(func)
	coroutine.wrap(func)()
end

local function safeFindChild(parent, name)
	local success, result = pcall(function() return parent:FindFirstChild(name) end)
	if success and result then return result end
	return nil
end

