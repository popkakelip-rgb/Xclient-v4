-- 1. COLLISION BOOST
local function startCollisionBoost()
	spawnTask(function()
		while CollisionBoostEnabled and isFlying do
			wait(0.1)
			
			if not rootPart or not rootPart.Parent then break end
			
			pcall(function()
				for _, otherPlayer in ipairs(Players:GetPlayers()) do
					if otherPlayer ~= player and otherPlayer.Character then
						local otherRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
						local otherHumanoid = otherPlayer.Character:FindFirstChild("Humanoid")
						
						if otherRoot and otherHumanoid and otherHumanoid.Health > 0 then
							local distance = (rootPart.Position - otherRoot.Position).Magnitude
							
							if distance <= CollisionBoostRadius then
								local direction = (rootPart.Position - otherRoot.Position).Unit
								if direction.Magnitude < 0.1 then
									direction = Vector3.new(math.random(), 1, math.random()).Unit
								end
								
								local boostForce = direction * CollisionBoostSpeed
								if rootPart.AssemblyLinearVelocity then
									rootPart.AssemblyLinearVelocity = boostForce
								else
									rootPart.Velocity = boostForce
								end
								
								local particle = Instance.new("ParticleEmitter")
								particle.Parent = rootPart
								particle.Texture = "rbxassetid://241685724"
								particle.Color = ColorSequence.new(Color3.fromRGB(255, 200, 100))
								particle.Size = NumberSequence.new(0.5)
								particle.Lifetime = NumberRange.new(0.2, 0.4)
								particle.Rate = 30
								particle.Speed = NumberRange.new(5, 10)
								particle:Emit(15)
								
								wait(0.3)
								particle:Destroy()
							end
						end
					end
				end
			end)
		end
	end)
end

-- 2. MINIJUMP
local function startMiniJump()
	spawnTask(function()
		while MiniJumpEnabled and isFlying do
			wait(0.05)
			
			if not rootPart or not rootPart.Parent then break end
			if not humanoid or humanoid.Health <= 0 then break end
			
			pcall(function()
				local jumpPower = MiniJumpSpeed / 3
				
				local currentY = 0
				if rootPart.AssemblyLinearVelocity then
					currentY = rootPart.AssemblyLinearVelocity.Y
				elseif rootPart.Velocity then
					currentY = rootPart.Velocity.Y
				end
				
				local newVel = Vector3.new(0, jumpPower, 0)
				
				if rootPart.AssemblyLinearVelocity then
					rootPart.AssemblyLinearVelocity = newVel
				else
					rootPart.Velocity = newVel
				end
			end)
		end
	end)
end

-- 3. SELF PUSH
local function findSlapGlove()
	local gloveName = SelfPushGlove
	
	if player.Backpack then
		for _, tool in ipairs(player.Backpack:GetChildren()) do
			if tool:IsA("Tool") and (tool.Name:lower():find(gloveName:lower()) or tool.Name == gloveName) then
				return tool
			end
		end
	end
	
	if character then
		for _, tool in ipairs(character:GetChildren()) do
			if tool:IsA("Tool") and (tool.Name:lower():find(gloveName:lower()) or tool.Name == gloveName) then
				return tool
			end
		end
	end
	
	local slapNames = {"Пощечина", "Slap", "пощечина", "slap", "Железная", "Золотая", "Алмазная", "Изумрудная", "Рубиновая", "Черная", "Солнечная", "Слизневая", "Галактическая", "Глитч", "Брызгающая", "Мармеладная"}
	
	if player.Backpack then
		for _, tool in ipairs(player.Backpack:GetChildren()) do
			if tool:IsA("Tool") then
				for _, name in ipairs(slapNames) do
					if tool.Name:lower():find(name:lower()) then
						return tool
					end
				end
			end
		end
	end
	
	if character then
		for _, tool in ipairs(character:GetChildren()) do
			if tool:IsA("Tool") then
				for _, name in ipairs(slapNames) do
					if tool.Name:lower():find(name:lower()) then
						return tool
					end
				end
			end
		end
	end
	
	return nil
end

local function activateSlapGlove()
	local glove = findSlapGlove()
	if not glove then
		createNotification("Пощечина не найдена в инвентаре!", 2)
		return false
	end
	
	if glove.Parent == player.Backpack then
		humanoid:EquipTool(glove)
		wait(0.1)
	end
	
	local activateRemote = nil
	
	for _, child in ipairs(glove:GetDescendants()) do
		if child:IsA("RemoteEvent") and (child.Name:lower():find("activate") or child.Name:lower():find("fire") or child.Name:lower():find("use") or child.Name:lower():find("slap")) then
			activateRemote = child
			break
		end
	end
	
	if not activateRemote then
		for _, child in ipairs(ReplicatedStorage:GetDescendants()) do
			if child:IsA("RemoteEvent") and (child.Name:lower():find("slap") or child.Name:lower():find("hit") or child.Name:lower():find("activate")) then
				activateRemote = child
				break
			end
		end
	end
	
	if activateRemote then
		pcall(function()
			activateRemote:FireServer(character, rootPart.Position)
			return true
		end)
	else
		pcall(function()
			humanoid.PlatformStand = true
			
			local randomDir = Vector3.new(math.random(-100, 100)/100, 1, math.random(-100, 100)/100).Unit
			local pushForce = randomDir * SelfPushSpeed
			
			if rootPart.AssemblyLinearVelocity then
				rootPart.AssemblyLinearVelocity = pushForce
			else
				rootPart.Velocity = pushForce
			end
			
			wait(0.1)
			humanoid.PlatformStand = false
			return true
		end)
	end
	
	return false
end

local function startSelfPush()
	spawnTask(function()
		while SelfPushEnabled and isFlying do
			wait(0.5)
			
			if not isFlying then break end
			if not rootPart or not rootPart.Parent then break end
			
			pcall(function()
				activateSlapGlove()
			end)
		end
	end)
end

-- ============================================
-- БАЗОВЫЙ ПОЛЕТ
-- ============================================
local function flightLoop(deltaTime)
	if not character or not character.Parent or not humanoid or humanoid.Health <= 0 then
		stopFlight()
		return
	end
	
	if not rootPart or not rootPart.Parent then
		stopFlight()
		return
	end

	local camera = Workspace.CurrentCamera
	if not camera then return end
	
	local cameraDirection = camera.CFrame.LookVector
	
	local moveDirection = Vector3.zero
	
	pcall(function()
		if humanoid.MoveDirection.Magnitude > 0 then
			moveDirection = (humanoid.MoveDirection.Z * cameraDirection + humanoid.MoveDirection.X * camera.CFrame.RightVector)
			if moveDirection.Magnitude > 0 then moveDirection = moveDirection.Unit end
		end
	end)
	
	if moveDirection.Magnitude < 0.1 then
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDirection += cameraDirection end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDirection -= cameraDirection end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDirection += camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDirection -= camera.CFrame.RightVector end
		if moveDirection.Magnitude > 0 then moveDirection = moveDirection.Unit end
	end
	
	if moveDirection.Magnitude < 0.1 then moveDirection = cameraDirection end
	
	local verticalInput = 0
	if UserInputService:IsKeyDown(Enum.KeyCode.Space) then verticalInput = 1 end
	if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then verticalInput = -1 end
	pcall(function() if humanoid.Jump then verticalInput = 1; humanoid.Jump = false end end)
	
	local newPosition = rootPart.Position + (moveDirection * FlightSpeed + Vector3.new(0, verticalInput * FlightSpeed * 0.8, 0)) * deltaTime
	
	pcall(function()
		rootPart.CFrame = CFrame.new(newPosition) * rootPart.CFrame.Rotation
		if rootPart.AssemblyLinearVelocity then
			rootPart.AssemblyLinearVelocity = Vector3.zero
			rootPart.AssemblyAngularVelocity = Vector3.zero
		else
			rootPart.Velocity = Vector3.zero
			rootPart.RotVelocity = Vector3.zero
		end
	end)
	
	-- DODGE в каждом кадре
	pcall(function()
		SmartDodge(rootPart, humanoid)
	end)
end

function startFlight()
	if flightConnection then return end
	
	pcall(function()
		humanoid.PlatformStand = true
		if rootPart.AssemblyLinearVelocity then
			rootPart.AssemblyLinearVelocity = Vector3.zero
		else
			rootPart.Velocity = Vector3.zero
		end
	end)
	
	isFlying = true
	flightConnection = RunService.Heartbeat:Connect(flightLoop)
	
	if CollisionBoostEnabled then startCollisionBoost() end
	if MiniJumpEnabled then startMiniJump() end
	if SelfPushEnabled then startSelfPush() end
end

function stopFlight()
	if flightConnection then
		pcall(function() flightConnection:Disconnect() end)
		flightConnection = nil
	end
	
	pcall(function()
		humanoid.PlatformStand = false
		if rootPart then
			if rootPart.AssemblyLinearVelocity then
				rootPart.AssemblyLinearVelocity = Vector3.zero
			else
				rootPart.Velocity = Vector3.zero
			end
		end
	end)
	
	isFlying = false
end

