-- // НОТИФИКАЦИИ // --
local function Notify(msg, duration)
    duration = duration or 3
    local notifyFrame = Instance.new("Frame")
    notifyFrame.Size = UDim2.new(0, 280, 0, 40)
    notifyFrame.Position = UDim2.new(1, 10, 0, 50)
    notifyFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    notifyFrame.BorderSizePixel = 0
    notifyFrame.BackgroundTransparency = 0.15
    notifyFrame.Parent = gui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = notifyFrame
    
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1, -10, 1, 0)
    text.Position = UDim2.new(0, 5, 0, 0)
    text.BackgroundTransparency = 1
    text.Text = msg
    text.TextColor3 = Color3.fromRGB(255, 255, 255)
    text.Font = Enum.Font.Gotham
    text.TextSize = 14
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.Parent = notifyFrame
    
    notifyFrame.Position = UDim2.new(1, 10, 0, 50)
    local tween = game:GetService("TweenService")
    local goal = {Position = UDim2.new(1, -290, 0, 50)}
    local fadeIn = tween:Create(notifyFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), goal)
    fadeIn:Play()
    
    task.wait(duration)
    local fadeOut = tween:Create(notifyFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = UDim2.new(1, 10, 0, 50)})
    fadeOut:Play()
    task.wait(0.3)
    notifyFrame:Destroy()
end

