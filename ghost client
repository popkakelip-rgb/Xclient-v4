-- DODGE СИСТЕМА
-- ============================================
local function getClosestThreat(hrp)
	local closest, vel, predicted
	local bestDist = DodgeRadius

	for _, p in pairs(Players:GetPlayers()) do
		if p ~= player and p.Character then
			local root = p.Character:FindFirstChild("HumanoidRootPart")

			if root then
				local v = root.AssemblyLinearVelocity or root.Velocity or Vector3.zero
				local future = root.Position + (v * DodgePredictTime)

				local dist = (future - hrp.Position).Magnitude

				if dist < bestDist then
					bestDist = dist
					closest = root
					vel = v
					predicted = future
				end
			end
		end
	end

	return closest, vel, predicted, bestDist
end

local function SmartDodge(hrp, hum)
	if not DodgeEnabled then return end
	if tick() - lastDodge < DodgeCooldown then return end

	local enemy, vel, predicted, dist = getClosestThreat(hrp)

	if enemy and predicted then
		-- Направление ОТ будущей позиции врага
		local away = (hrp.Position - predicted)

		if away.Magnitude == 0 then return end
		away = away.Unit

		-- Учитываем движение игрока
		local moveDir = hum.MoveDirection

		-- Смешиваем направления (плавный dodge)
		local finalDir = (away * 0.8 + moveDir * 0.3)
		if finalDir.Magnitude < 0.01 then
			finalDir = away
		end
		finalDir = finalDir.Unit

		-- Сила зависит от скорости врага
		local enemySpeed = vel.Magnitude
		local force = DodgeBaseForce + (enemySpeed * DodgeSpeedMultiplier)

		-- Применение velocity dodge
		local currentY = hrp.Velocity.Y or 0
		if hrp.AssemblyLinearVelocity then
			currentY = hrp.AssemblyLinearVelocity.Y
		end
		
		pcall(function()
			if hrp.AssemblyLinearVelocity then
				hrp.AssemblyLinearVelocity = Vector3.new(
					finalDir.X * force,
					currentY,
					finalDir.Z * force
				)
			elseif hrp.Velocity then
				hrp.Velocity = Vector3.new(
					finalDir.X * force,
					currentY,
					finalDir.Z * force
				)
			end
		end)

		lastDodge = tick()
		
		-- Визуальный эффект доджа
		pcall(function()
			local dodgeEffect = Instance.new("ParticleEmitter")
			dodgeEffect.Parent = hrp
			dodgeEffect.Texture = "rbxassetid://241685724"
			dodgeEffect.Color = ColorSequence.new(Color3.fromRGB(100, 200, 255))
			dodgeEffect.Size = NumberSequence.new(0.3)
			dodgeEffect.Lifetime = NumberRange.new(0.1, 0.3)
			dodgeEffect.Rate = 20
			dodgeEffect.Speed = NumberRange.new(2, 5)
			dodgeEffect:Emit(10)
			
			wait(0.2)
			dodgeEffect:Destroy()
		end)
	end
end

