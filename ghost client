local espEnabled = false
local espObjects = {}

-- Функция создания ESP (бокс + имя)
local function createESP(character)
    if not espEnabled then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    if character.Name == player.Name then return end

local box = Instance.new("BoxHandleAdornment")
    box.Size = Vector3.new(3, 5, 3)
    box.Adornee = character
    box.Color3 = Color3.fromRGB(255, 70, 120)
    box.AlwaysOnTop = true
    box.ZIndex = 10
    box.Parent = character
    
    local nameTag = Instance.new("BillboardGui")
    nameTag.Size = UDim2.new(0, 100, 0, 30)
    nameTag.Adornee = character
    nameTag.StudsOffset = Vector3.new(0, 3, 0)
    nameTag.Parent = character
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = character.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextStrokeTransparency = 0.3
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextSize = 12
    nameLabel.Parent = nameTag
    
    table.insert(espObjects, {box = box, tag = nameTag, char = character})
end

local function clearESP()
    for _, obj in pairs(espObjects) do
        if obj.box and obj.box.Parent then obj.box:Destroy() end
        if obj.tag and obj.tag.Parent then obj.tag:Destroy() end
    end
    espObjects = {}
end

espToggle.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    if espEnabled then
        espToggle.BackgroundColor3 = Color3.fromRGB(80, 220, 100)
        espToggle.Text = "ESP: ON"
        for _, char in pairs(workspace:GetChildren()) do
            if char:FindFirstChild("Humanoid") then
                createESP(char)
            end
        end
    else
        espToggle.BackgroundColor3 = Color3.fromRGB(255, 70, 120)
        espToggle.Text = "ESP: OFF"
        clearESP()
    end
end)

-- Отслеживание новых персонажей
workspace.ChildAdded:Connect(function(child)
    if espEnabled and child:FindFirstChild("Humanoid") then
        createESP(child)
    end
end)

workspace.ChildRemoved:Connect(function(child)
    if espEnabled then
        for i, obj in pairs(espObjects) do
            if obj.char == child then
                if obj.box then obj.box:Destroy() end
                if obj.tag then obj.tag:Destroy() end
                table.remove(espObjects, i)
                break
            end
        end
    end
end)

