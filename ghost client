-- ESP кнопка
local espBtn = Instance.new("TextButton")
espBtn.Size = UDim2.new(0, 200, 0, 50)
espBtn.Position = UDim2.new(0.5, -100, 0.5, -25)
espBtn.BackgroundColor3 = Color3.fromRGB(255, 70, 120)
espBtn.Text = "ESP: OFF"
espBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
espBtn.Font = Enum.Font.Gotham
espBtn.TextSize = 18
espBtn.BorderSizePixels = 0
espBtn.Parent = mainFrame

local espCorner = Instance.new("UICorner")
espCorner.CornerRadius = UDim.new(0, 8)
espCorner.Parent = espBtn

local espEnabled = false
local espObjects = {}

local function clearESP()
    for _, obj in pairs(espObjects) do
        pcall(function() obj:Destroy() end)
    end
    espObjects = {}
end

local function addESP(char)
    if not espEnabled then return end
    if char == player.Character then return end
    if not char:FindFirstChild("Humanoid") then return end
    
    local box = Instance.new("BoxHandleAdornment")
    box.Size = Vector3.new(3, 5, 3)
    box.Adornee = char
    box.Color3 = Color3.fromRGB(255, 70, 120)
    box.AlwaysOnTop = true
    box.ZIndex = 10
    box.Parent = char
    table.insert(espObjects, box)
end

espBtn.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    if espEnabled then
        espBtn.BackgroundColor3 = Color3.fromRGB(80, 220, 100)
        espBtn.Text = "ESP: ON"
        for _, child in pairs(workspace:GetChildren()) do
            addESP(child)
        end
    else
        espBtn.BackgroundColor3 = Color3.fromRGB(255, 70, 120)
        espBtn.Text = "ESP: OFF"
        clearESP()
    end
end)

workspace.ChildAdded:Connect(function(child)
    if espEnabled then
        addESP(child)
    end
end)

